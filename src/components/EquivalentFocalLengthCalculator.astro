<equivalent-focal-length-calculator class="block">
	<div class="grid gap-4 md:grid-cols-[minmax(0,1.1fr)_minmax(18rem,0.9fr)]">
		<form class="tool-panel space-y-4" data-equivalent-form>
			<div class="space-y-2">
				<p class="tool-field-label">Equivalent Focal Length</p>
				<p class="tool-lede">
					Convert a focal length between common sensor sizes using crop factor.
				</p>
			</div>
			<div class="grid gap-4 sm:grid-cols-[minmax(0,0.8fr)_minmax(0,1fr)]">
				<label class="space-y-2">
					<span class="tool-field-label">Focal Length</span>
					<input
						class="tool-input"
						autocomplete="off"
						inputmode="decimal"
						min="1"
						name="equivalent-focal-length"
						step="0.1"
						type="number"
						value="35"
					/>
				</label>
				<label class="space-y-2">
					<span class="tool-field-label">Source Sensor</span>
					<select class="tool-select" autocomplete="off" name="source-crop-factor">
						<option value="1.5">APS-C / Super 35 (1.5x)</option>
						<option value="1">Full frame (1.0x)</option>
						<option value="1.6">APS-C Canon (1.6x)</option>
						<option value="2">Micro Four Thirds (2.0x)</option>
						<option value="2.7">1-inch sensor (2.7x)</option>
						<option value="custom">Custom crop factor</option>
					</select>
				</label>
			</div>
			<div class="grid gap-4 sm:grid-cols-[minmax(0,1fr)_minmax(0,0.7fr)]">
				<label class="space-y-2">
					<span class="tool-field-label">Target Sensor</span>
					<select class="tool-select" autocomplete="off" name="target-crop-factor">
						<option value="1">Full frame (1.0x)</option>
						<option value="1.5">APS-C / Super 35 (1.5x)</option>
						<option value="1.6">APS-C Canon (1.6x)</option>
						<option value="2">Micro Four Thirds (2.0x)</option>
						<option value="2.7">1-inch sensor (2.7x)</option>
						<option value="custom">Custom crop factor</option>
					</select>
				</label>
				<label class="space-y-2">
					<span class="tool-field-label">Custom Crop</span>
					<input
						class="tool-input"
						autocomplete="off"
						inputmode="decimal"
						min="0.1"
						name="custom-crop-factor"
						step="0.1"
						type="number"
						value="1"
					/>
				</label>
			</div>
		</form>

		<div class="tool-panel space-y-4">
			<div>
				<p class="tool-field-label">Equivalent Focal Length</p>
				<p class="tool-readout mt-3" data-output>52.5 mm</p>
				<p class="tool-lede mt-3" data-summary>
					A 35 mm lens on APS-C / Super 35 gives the same angle of view as a 52.5 mm lens on full
					frame.
				</p>
			</div>
			<div class="tool-status p-3 text-xs leading-relaxed">
				<p>Equivalent focal length = focal length × (target crop factor / source crop factor)</p>
				<p class="mt-2">
					Crop factor compares a sensor's angle of view to full frame. This conversion only changes
					framing equivalence, not the physical focal length of the lens.
				</p>
			</div>
		</div>
	</div>
</equivalent-focal-length-calculator>

<script>
	import { equivalentFocalLength, formatFocalLength } from "@/lib/tools/optics";

	class EquivalentFocalLengthCalculatorElement extends HTMLElement {
		connectedCallback() {
			const form = this.querySelector("[data-equivalent-form]") as HTMLFormElement | null;
			const focalLengthInput = this.querySelector(
				'input[name="equivalent-focal-length"]',
			) as HTMLInputElement | null;
			const sourceCropFactorInput = this.querySelector(
				'select[name="source-crop-factor"]',
			) as HTMLSelectElement | null;
			const targetCropFactorInput = this.querySelector(
				'select[name="target-crop-factor"]',
			) as HTMLSelectElement | null;
			const customCropFactorInput = this.querySelector(
				'input[name="custom-crop-factor"]',
			) as HTMLInputElement | null;
			const output = this.querySelector("[data-output]") as HTMLElement | null;
			const summary = this.querySelector("[data-summary]") as HTMLElement | null;

			if (
				!form ||
				!focalLengthInput ||
				!sourceCropFactorInput ||
				!targetCropFactorInput ||
				!customCropFactorInput ||
				!output ||
				!summary
			) {
				return;
			}

			const cropFactorLabels: Record<string, string> = {
				"1": "full frame",
				"1.5": "APS-C / Super 35",
				"1.6": "APS-C Canon",
				"2": "Micro Four Thirds",
				"2.7": "1-inch sensor",
				custom: "custom sensor",
			};

			const getCropFactor = (input: HTMLSelectElement) => {
				if (input.value === "custom") {
					return Number(customCropFactorInput.value);
				}

				return Number(input.value);
			};

			const getSensorLabel = (input: HTMLSelectElement) => {
				if (input.value === "custom") {
					const customCropFactor = Number(customCropFactorInput.value);
					return Number.isFinite(customCropFactor) && customCropFactor > 0
						? `custom ${customCropFactor.toFixed(1)}x crop`
						: cropFactorLabels.custom;
				}

				return cropFactorLabels[input.value] ?? "selected sensor";
			};

			const update = () => {
				const focalLength = Number(focalLengthInput.value);
				const sourceCropFactor = getCropFactor(sourceCropFactorInput);
				const targetCropFactor = getCropFactor(targetCropFactorInput);
				const result = equivalentFocalLength(focalLength, sourceCropFactor, targetCropFactor);

				if (result === null) {
					output.textContent = "Invalid input";
					summary.textContent = "Enter positive values for focal length and crop factor.";
					return;
				}

				const sourceLabel = getSensorLabel(sourceCropFactorInput);
				const targetLabel = getSensorLabel(targetCropFactorInput);

				output.textContent = formatFocalLength(result);
				summary.textContent =
					`A ${formatFocalLength(focalLength)} lens on ${sourceLabel} gives the same angle ` +
					`of view as a ${formatFocalLength(result)} lens on ${targetLabel}.`;
			};

			form.addEventListener("input", update);

			update();
		}
	}

	customElements.define(
		"equivalent-focal-length-calculator",
		EquivalentFocalLengthCalculatorElement,
	);
</script>
