---
import { WEBMENTION_PINGBACK, WEBMENTION_URL } from "astro:env/client";
import {
	DEFAULT_SITE_LANG,
	getBlogRssPath,
	SITE_LANG_COOKIE_KEY,
	SITE_LANG_QUERY_KEY,
	SITE_LANG_STORAGE_KEY,
} from "@/lib/i18n";
import { siteConfig } from "@/site.config";
import type { SiteMeta } from "@/types";
import "@/styles/global.css";

type Props = SiteMeta;

const {
	alternates = [],
	articleDate,
	description,
	lang = siteConfig.lang,
	ogImage,
	ogLocale = siteConfig.ogLocale,
	rssHref = getBlogRssPath(DEFAULT_SITE_LANG),
	title,
} = Astro.props;

const titleSeparator = "•";
const siteTitle = `${title} ${titleSeparator} ${siteConfig.title}`;
const canonicalURL = new URL(Astro.url.pathname + Astro.url.search, Astro.site);
const socialImageURL = new URL(ogImage ? ogImage : "/social-card.png", Astro.url).href;
const isWorkersPreviewHost = Astro.url.hostname.endsWith(".workers.dev");
const shouldIncludeManifest = import.meta.env.PROD && !isWorkersPreviewHost;
---

<meta charset="utf-8" />
<meta
	content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no"
	name="viewport"
/>
<title>{siteTitle}</title>

{/* Icons */}
<link href="/favicon-32x32.png" rel="icon" type="image/png" />
{
	import.meta.env.PROD && (
		<>
			{/* Favicon & Apple Icon */}
			<link rel="icon" href="/favicon-32x32.png" type="image/png" />
			<link href="/icons/apple-touch-icon.png" rel="apple-touch-icon" />
			{shouldIncludeManifest && <link href="/manifest.webmanifest" rel="manifest" />}
		</>
	)
}

{/* Canonical URL */}
<link href={canonicalURL} rel="canonical" />
{
	alternates.map((alternate) => (
		<link href={alternate.href} hreflang={alternate.hreflang} rel="alternate" />
	))
}

{/* Primary Meta Tags */}
<meta content={siteTitle} name="title" />
<meta content={description} name="description" />
<meta content={siteConfig.author} name="author" />

{/* Open Graph / Facebook */}
<meta content={articleDate ? "article" : "website"} property="og:type" />
<meta content={title} property="og:title" />
<meta content={description} property="og:description" />
<meta content={canonicalURL} property="og:url" />
<meta content={siteConfig.title} property="og:site_name" />
<meta content={ogLocale} property="og:locale" />
<meta content={socialImageURL} property="og:image" />
<meta content="1200" property="og:image:width" />
<meta content="630" property="og:image:height" />
{
	articleDate && (
		<>
			<meta content={siteConfig.author} property="article:author" />
			<meta content={articleDate} property="article:published_time" />
		</>
	)
}

{/* Twitter */}
<meta content="summary_large_image" property="twitter:card" />
<meta content={canonicalURL} property="twitter:url" />
<meta content={title} property="twitter:title" />
<meta content={description} property="twitter:description" />
<meta content={socialImageURL} property="twitter:image" />

{/* Sitemap */}
<link href="/sitemap-index.xml" rel="sitemap" />

{/* RSS auto-discovery */}
<link href={rssHref} title="Blog" rel="alternate" type="application/rss+xml" />
<link href="/notes/rss.xml" title="Notes" rel="alternate" type="application/rss+xml" />

{/* Webmentions */}
{
	WEBMENTION_URL && (
		<>
			<link href={WEBMENTION_URL} rel="webmention" />
			{WEBMENTION_PINGBACK && <link href={WEBMENTION_PINGBACK} rel="pingback" />}
		</>
	)
}

<meta content={Astro.generator} name="generator" />
<meta content={lang} name="language" />

<script
	is:inline
	define:vars={{
		cookieKey: SITE_LANG_COOKIE_KEY,
		legacyStorageKey: "blog-language",
		queryKey: SITE_LANG_QUERY_KEY,
		storageKey: SITE_LANG_STORAGE_KEY,
	}}
>
	(() => {
		const normalizeLang = (value) => {
			if (!value) return undefined;
			const normalized = value.toLowerCase();
			if (normalized === "en") return "en";
			if (normalized === "ja" || normalized === "jp" || normalized === "ja-jp") return "ja";
			if (normalized === "zh" || normalized === "cn" || normalized === "zh-cn") return "zh";
			return undefined;
		};
		const readCookie = (name) =>
			document.cookie
				.split("; ")
				.find((entry) => entry.startsWith(`${name}=`))
				?.slice(name.length + 1);
		const writeCookie = (name, value) => {
			document.cookie = `${name}=${value}; path=/; max-age=31536000; SameSite=Lax`;
		};
		const migrateLegacyStorage = () => {
			const currentValue = normalizeLang(localStorage.getItem(storageKey));
			if (currentValue) return currentValue;
			const legacyValue = normalizeLang(localStorage.getItem(legacyStorageKey));
			if (!legacyValue) return undefined;
			localStorage.setItem(storageKey, legacyValue);
			localStorage.removeItem(legacyStorageKey);
			return legacyValue;
		};
		const params = new URLSearchParams(window.location.search);
		const explicitLang = normalizeLang(params.get(queryKey));
		if (explicitLang) {
			localStorage.setItem(storageKey, explicitLang);
			localStorage.removeItem(legacyStorageKey);
			writeCookie(cookieKey, explicitLang);
			return;
		}

		const storedLang = migrateLegacyStorage();
		const browserLang = normalizeLang(navigator.languages?.[0] ?? navigator.language);
		const preferredLang = storedLang ?? browserLang;
		if (!preferredLang) return;
		const cookieLang = normalizeLang(readCookie(cookieKey));
		if (cookieLang === preferredLang) return;
		writeCookie(cookieKey, preferredLang);
		window.location.replace(`${window.location.pathname}${window.location.hash}`);
	})();
</script>
