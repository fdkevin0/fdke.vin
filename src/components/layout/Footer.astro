---
import { siteConfig } from "@/site.config";

const year = new Date().getFullYear();
---

<footer
	class="mt-auto flex w-full items-center justify-center pt-20 pb-4 text-center align-top text-xs font-semibold text-gray-600 dark:text-gray-400"
>
	<div>
		&copy; {year}
		{siteConfig.author}.<span class="inline-block">&nbsp;{siteConfig.title}</span>
	</div>
</footer>
