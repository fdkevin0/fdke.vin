---
import type { CollectionEntry } from "astro:content";
import type { HTMLTag, Polymorphic } from "astro/types";
import FormattedDate from "@/components/FormattedDate.astro";
import { getPostPath } from "@/lib/blog-i18n";

type Props<Tag extends HTMLTag> = Polymorphic<{ as: Tag }> & {
	explicitLanguage?: boolean;
	post: CollectionEntry<"post">;
	withDesc?: boolean;
};

const { as: Tag = "div", explicitLanguage = false, post, withDesc = false } = Astro.props;
---

<FormattedDate
	class="min-w-30 font-semibold text-gray-600 dark:text-gray-400"
	date={post.data.publishDate}
/>
<Tag>
	{post.data.draft && <span class="text-red-500">(Draft) </span>}
	<a class="cactus-link" href={getPostPath(post, explicitLanguage)}>
		{post.data.title}
	</a>
</Tag>
{withDesc && <q class="line-clamp-3 italic">{post.data.description}</q>}
