{/* Inlined to avoid FOUC. This is a parser blocking script. */}
<script is:inline>
	const darkModePref = window.matchMedia("(prefers-color-scheme: dark)");
	const THEME_KEY = "theme";
	const VALID_THEMES = new Set(["system", "light", "dark"]);

	function isValidTheme(theme) {
		return typeof theme === "string" && VALID_THEMES.has(theme);
	}

	function getStoredTheme() {
		if (typeof localStorage === "undefined") return null;
		const storedTheme = localStorage.getItem(THEME_KEY);
		return isValidTheme(storedTheme) ? storedTheme : null;
	}

	function getPreferredTheme() {
		return getStoredTheme() || "system";
	}

	function resolveTheme(theme) {
		if (theme === "system") {
			return darkModePref.matches ? "dark" : "light";
		}

		return theme;
	}

	function applyTheme(preferredTheme) {
		if (!isValidTheme(preferredTheme)) {
			return console.warn(
				`Invalid theme value '${preferredTheme}' received. Expected 'system', 'light', or 'dark'.`,
			);
		}

		const root = document.documentElement;
		const resolvedTheme = resolveTheme(preferredTheme);

		root.setAttribute("data-theme", resolvedTheme);
		root.setAttribute("data-theme-preference", preferredTheme);
	}

	function setThemePreference(newTheme) {
		applyTheme(newTheme);

		if (typeof localStorage !== "undefined") {
			if (newTheme === "system") {
				localStorage.removeItem(THEME_KEY);
			} else {
				localStorage.setItem(THEME_KEY, newTheme);
			}
		}
	}

	// initial setup
	applyTheme(getPreferredTheme());

	// View Transitions hook to restore theme
	document.addEventListener("astro:after-swap", () => applyTheme(getPreferredTheme()));

	// listen for theme-change custom event, fired in src/components/ThemeToggle.astro
	document.addEventListener("theme-change", (e) => {
		setThemePreference(e.detail.theme);
	});

	// If the user is following the system theme, update on OS changes.
	darkModePref.addEventListener("change", () => {
		if (getPreferredTheme() === "system") {
			applyTheme("system");
		}
	});
</script>
