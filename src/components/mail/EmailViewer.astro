---
export interface EmailViewerProps {
	emailKey: string;
}

const { emailKey } = Astro.props;
---

<script>
	interface ParsedEmail {
		headers: Record<string, string>;
		subject: string;
		from: string;
		to: string;
		date: string;
		plainText: string;
		htmlContent: string;
	}

	async function fetchEmailContent(emailKey: string) {
		try {
			const response = await fetch(`/api/emails/${encodeURIComponent(emailKey)}`);

			if (!response.ok) {
				throw new Error(`Failed to fetch email: ${response.statusText}`);
			}

			const content = await response.text();
			const parsedEmail = parseEmail(content);

			const emailViewer = document.getElementById("email-viewer");
			if (!emailViewer) return;

			emailViewer.innerHTML = `
				<div class="border-b border-zinc-200 bg-zinc-50 p-4 dark:border-zinc-800 dark:bg-zinc-900/70">
					<h2 class="text-xl font-semibold text-zinc-900 dark:text-zinc-100">${parsedEmail.subject || "Untitled email"}</h2>
					<div class="mt-3 grid gap-2 text-sm text-zinc-600 dark:text-zinc-300">
						<div><span class="font-medium text-zinc-900 dark:text-zinc-100">From:</span> ${parsedEmail.from || "Unknown"}</div>
						<div><span class="font-medium text-zinc-900 dark:text-zinc-100">To:</span> ${parsedEmail.to || "Unknown"}</div>
						<div><span class="font-medium text-zinc-900 dark:text-zinc-100">Date:</span> ${parsedEmail.date || "Unknown"}</div>
					</div>
				</div>
				<div class="p-4 text-sm leading-relaxed text-zinc-700 dark:text-zinc-200">
					${
						parsedEmail.htmlContent
							? parsedEmail.htmlContent
							: `<pre class="whitespace-pre-wrap rounded bg-zinc-50 p-4 text-sm text-zinc-700 dark:bg-zinc-900/70 dark:text-zinc-200">${parsedEmail.plainText}</pre>`
					}
				</div>
			`;
		} catch (err) {
			console.error("Error fetching email content:", err);
			const emailViewer = document.getElementById("email-viewer");
			if (emailViewer) {
				emailViewer.innerHTML = `<div class="rounded border border-red-300 bg-red-50 p-4 text-center text-sm text-red-800 dark:border-red-800 dark:bg-red-900/20 dark:text-red-300">Error: ${err instanceof Error ? err.message : "Failed to fetch email content"}</div>`;
			}
		}
	}

	function parseEmail(emailData: string): ParsedEmail {
		const lines = emailData.split("\n");
		const headers: Record<string, string> = {};
		let inHeaders = true;
		let boundary = "";
		let currentPart = "";
		let inPart = false;
		let plainText = "";
		let htmlContent = "";

		const boundaryMatch = emailData.match(/boundary="([^"]+)"/);
		if (boundaryMatch?.[1]) {
			boundary = boundaryMatch[1];
		}

		for (let i = 0; i < lines.length; i++) {
			const line = lines[i];
			if (!line) continue;

			if (inHeaders) {
				if (line.trim() === "") {
					inHeaders = false;
					continue;
				}

				if (line.match(/^\S+:/)) {
					const [key, ...valueParts] = line.split(":");
					if (key) {
						const value = valueParts.join(":").trim();
						headers[key.toLowerCase()] = value;
					}
				} else if (line.match(/^\s+/) && Object.keys(headers).length > 0) {
					const lastHeader = Object.keys(headers).pop();
					if (!lastHeader) continue;
					headers[lastHeader] += " " + line.trim();
				}
			} else {
				if (boundary && line.includes(boundary)) {
					if (inPart) {
						if (currentPart.includes("Content-Type: text/plain")) {
							plainText = extractContent(currentPart);
						} else if (currentPart.includes("Content-Type: text/html")) {
							htmlContent = extractContent(currentPart);
						}
						currentPart = "";
					}
					inPart = !line.includes("--" + boundary + "--");
				} else if (inPart) {
					currentPart += line + "\n";
				}
			}
		}

		return {
			headers,
			subject: headers["subject"] || "",
			from: headers["from"] || "",
			to: headers["to"] || "",
			date: headers["date"] || "",
			plainText,
			htmlContent,
		};
	}

	function extractContent(partData: string): string {
		const encodingMatch = partData.match(/Content-Transfer-Encoding:\s*([^\s]+)/i);
		const encoding = encodingMatch?.[1] ? encodingMatch[1].toLowerCase() : "none";

		const contentLines = partData.split("\n\n").slice(1).join("\n\n");

		if (encoding === "base64") {
			try {
				return atob(contentLines.trim());
			} catch (e) {
				return `[Failed to decode base64 content: ${e instanceof Error ? e.message : String(e)}]`;
			}
		}

		return contentLines.trim();
	}

	const emailViewer = document.getElementById("email-viewer");
	const emailKey = emailViewer?.dataset.emailKey;

	if (emailKey) {
		fetchEmailContent(emailKey);
	}
</script>

<div
	id="email-viewer"
	data-email-key={emailKey}
	class="overflow-hidden rounded border border-zinc-200 dark:border-zinc-800"
>
	<div class="p-4 text-center text-sm text-zinc-600 dark:text-zinc-300">Loading email...</div>
</div>
