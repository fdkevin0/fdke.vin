---
import { Code } from "astro-expressive-code/components";

export interface EmailViewerProps {
	emailKey: string;
}

const { emailKey } = Astro.props;
---

<script>
	interface ParsedEmail {
		headers: Record<string, string>;
		subject: string;
		from: string;
		to: string;
		date: string;
		plainText: string;
		htmlContent: string;
	}

	async function fetchEmailContent(emailKey: string) {
		try {
			const response = await fetch(`/api/emails/${encodeURIComponent(emailKey)}`);

			if (!response.ok) {
				throw new Error(`Failed to fetch email: ${response.statusText}`);
			}

			const content = await response.text();
			const parsedEmail = parseEmail(content);

			const loadingState = document.getElementById("email-loading-state");
			const header = document.getElementById("email-header");
			const htmlBody = document.getElementById("email-html-body");
			const plainTextBody = document.getElementById("email-plain-text-body");
			const plainTextCode = document.querySelector("#email-plain-text-body code");
			const subject = document.getElementById("email-subject");
			const from = document.getElementById("email-from");
			const to = document.getElementById("email-to");
			const date = document.getElementById("email-date");

			if (!loadingState || !header || !htmlBody || !plainTextBody || !subject || !from || !to || !date) {
				return;
			}

			subject.textContent = parsedEmail.subject || "Untitled email";
			from.textContent = parsedEmail.from || "Unknown";
			to.textContent = parsedEmail.to || "Unknown";
			date.textContent = parsedEmail.date || "Unknown";

			header.classList.remove("hidden");
			loadingState.classList.add("hidden");

			if (parsedEmail.htmlContent) {
				htmlBody.innerHTML = parsedEmail.htmlContent;
				htmlBody.classList.remove("hidden");
				plainTextBody.classList.add("hidden");
			} else {
				htmlBody.innerHTML = "";
				if (plainTextCode) {
					plainTextCode.textContent = parsedEmail.plainText || "(Empty email body)";
				}
				htmlBody.classList.add("hidden");
				plainTextBody.classList.remove("hidden");
			}
		} catch (err) {
			console.error("Error fetching email content:", err);
			const errorState = document.getElementById("email-error-state");
			const errorMessage = document.getElementById("email-error-message");
			const loadingState = document.getElementById("email-loading-state");
			if (errorState && errorMessage) {
				errorMessage.textContent = err instanceof Error ? err.message : "Failed to fetch email content";
				errorState.classList.remove("hidden");
			}
			if (loadingState) {
				loadingState.classList.add("hidden");
			}
		}
	}

	function parseEmail(emailData: string): ParsedEmail {
		const lines = emailData.split("\n");
		const headers: Record<string, string> = {};
		let inHeaders = true;
		let boundary = "";
		let currentPart = "";
		let inPart = false;
		let plainText = "";
		let htmlContent = "";

		const boundaryMatch = emailData.match(/boundary="([^"]+)"/);
		if (boundaryMatch?.[1]) {
			boundary = boundaryMatch[1];
		}

		for (let i = 0; i < lines.length; i++) {
			const line = lines[i];
			if (!line) continue;

			if (inHeaders) {
				if (line.trim() === "") {
					inHeaders = false;
					continue;
				}

				if (line.match(/^\S+:/)) {
					const [key, ...valueParts] = line.split(":");
					if (key) {
						const value = valueParts.join(":").trim();
						headers[key.toLowerCase()] = value;
					}
				} else if (line.match(/^\s+/) && Object.keys(headers).length > 0) {
					const lastHeader = Object.keys(headers).pop();
					if (!lastHeader) continue;
					headers[lastHeader] += " " + line.trim();
				}
			} else {
				if (boundary && line.includes(boundary)) {
					if (inPart) {
						if (currentPart.includes("Content-Type: text/plain")) {
							plainText = extractContent(currentPart);
						} else if (currentPart.includes("Content-Type: text/html")) {
							htmlContent = extractContent(currentPart);
						}
						currentPart = "";
					}
					inPart = !line.includes("--" + boundary + "--");
				} else if (inPart) {
					currentPart += line + "\n";
				}
			}
		}

		return {
			headers,
			subject: headers["subject"] || "",
			from: headers["from"] || "",
			to: headers["to"] || "",
			date: headers["date"] || "",
			plainText,
			htmlContent,
		};
	}

	function extractContent(partData: string): string {
		const encodingMatch = partData.match(/Content-Transfer-Encoding:\s*([^\s]+)/i);
		const encoding = encodingMatch?.[1] ? encodingMatch[1].toLowerCase() : "none";

		const contentLines = partData.split("\n\n").slice(1).join("\n\n");

		if (encoding === "base64") {
			try {
				return atob(contentLines.trim());
			} catch (e) {
				return `[Failed to decode base64 content: ${e instanceof Error ? e.message : String(e)}]`;
			}
		}

		return contentLines.trim();
	}

	const emailViewer = document.getElementById("email-viewer");
	const emailKey = emailViewer?.dataset.emailKey;

	if (emailKey) {
		fetchEmailContent(emailKey);
	}
</script>

<div
	id="email-viewer"
	data-email-key={emailKey}
	class="overflow-hidden rounded border border-zinc-200 dark:border-zinc-800"
>
	<div id="email-loading-state" class="p-4 text-center text-sm text-zinc-600 dark:text-zinc-300">
		Loading email...
	</div>
	<div id="email-error-state" class="hidden p-4">
		<div class="rounded border border-red-300 bg-red-50 p-4 text-center text-sm text-red-800 dark:border-red-800 dark:bg-red-900/20 dark:text-red-300">
			Error: <span id="email-error-message">Failed to fetch email content</span>
		</div>
	</div>
	<div id="email-header" class="hidden border-b border-zinc-200 bg-zinc-50 p-4 dark:border-zinc-800 dark:bg-zinc-900/70">
		<h2 id="email-subject" class="text-xl font-semibold text-zinc-900 dark:text-zinc-100">Untitled email</h2>
		<div class="mt-3 grid gap-2 text-sm text-zinc-600 dark:text-zinc-300">
			<div><span class="font-medium text-zinc-900 dark:text-zinc-100">From:</span> <span id="email-from">Unknown</span></div>
			<div><span class="font-medium text-zinc-900 dark:text-zinc-100">To:</span> <span id="email-to">Unknown</span></div>
			<div><span class="font-medium text-zinc-900 dark:text-zinc-100">Date:</span> <span id="email-date">Unknown</span></div>
		</div>
	</div>
	<div id="email-html-body" class="hidden p-4 text-sm leading-relaxed text-zinc-700 dark:text-zinc-200"></div>
	<div id="email-plain-text-body" class="hidden p-4">
		<div class="overflow-hidden rounded border border-zinc-200 dark:border-zinc-800">
			<Code code="Loading plain text email..." lang="plaintext" />
		</div>
	</div>
</div>
