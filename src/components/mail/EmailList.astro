<script>
	interface EmailMetadata {
		name: string;
		size: number;
		date: string;
		type: string;
		contentType: string;
		from: string;
		to: string;
		subject: string;
	}

	interface Email {
		key: string;
		size: number;
		date: string;
		metadata: EmailMetadata;
	}

	interface EmailsResponse {
		emails: Email[];
	}

	async function fetchEmails() {
		try {
			const response = await fetch("/api/emails");

			if (!response.ok) {
				throw new Error(`Failed to fetch emails: ${response.statusText}`);
			}

			const data: EmailsResponse = await response.json();
			const emails = data.emails || [];

			const tbody = document.querySelector("tbody");
			if (!tbody) return;

			tbody.innerHTML = "";

			if (emails.length === 0) {
				tbody.innerHTML = `<tr><td colspan="7" class="px-4 py-8 text-center text-sm text-[var(--tool-muted)] md:px-6">No emails found in R2 storage.</td></tr>`;
				return;
			}

			emails.forEach((email) => {
				const tr = document.createElement("tr");
				tr.className =
					"border-b border-[var(--tool-line)] last:border-0 hover:bg-[color-mix(in_oklab,var(--tool-paper)_82%,var(--tool-line))]";

				const dateDisplay =
					email.date === "Unknown" || isNaN(new Date(email.date).getTime())
						? "Unknown"
						: new Date(email.date).toLocaleString();

				tr.innerHTML = `
					<td class="px-4 py-4 align-top text-sm md:px-6">
						<a href="/tools/mail/email/${encodeURIComponent(email.key)}" class="font-medium text-[var(--tool-ink)] break-words hover:underline focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--tool-teal)]">
							${email.metadata?.name || email.key}
						</a>
					</td>
					<td class="px-4 py-4 align-top text-sm text-[var(--tool-muted)] tabular-nums md:px-6">${formatFileSize(email.size)}</td>
					<td class="px-4 py-4 align-top text-sm text-[var(--tool-muted)] tabular-nums md:px-6">${dateDisplay}</td>
					<td class="px-4 py-4 align-top text-sm text-[var(--tool-muted)] md:px-6">${email.metadata?.type || "unknown"}</td>
					<td class="px-4 py-4 align-top text-sm text-[var(--tool-muted)] break-words md:px-6">${email.metadata?.from || "unknown"}</td>
					<td class="px-4 py-4 align-top text-sm text-[var(--tool-muted)] break-words md:px-6">${email.metadata?.to || "unknown"}</td>
					<td class="px-4 py-4 align-top text-sm text-[var(--tool-muted)] break-words md:px-6">${email.metadata?.subject || "unknown"}</td>
				`;
				tbody.appendChild(tr);
			});

			const loadingEl = document.getElementById("loading");
			if (loadingEl) loadingEl.style.display = "none";
		} catch (err) {
			console.error("Error fetching emails:", err);
			const errorEl = document.getElementById("error");
			if (errorEl) {
				errorEl.textContent = `Error: ${err instanceof Error ? err.message : "Failed to fetch emails"}`;
				errorEl.style.display = "block";
			}
			const loadingEl = document.getElementById("loading");
			if (loadingEl) loadingEl.style.display = "none";
		}
	}

	function formatFileSize(bytes: number): string {
		if (bytes === 0) return "0 Bytes";

		const k = 1024;
		const sizes = ["Bytes", "KB", "MB", "GB"];
		const i = Math.floor(Math.log(bytes) / Math.log(k));

		return parseFloat((bytes / Math.pow(k, i)).toFixed(2)) + " " + sizes[i];
	}

	fetchEmails();
</script>

<div class="w-full space-y-4">
	<div class="space-y-1">
		<h2 class="text-lg font-semibold">Emails</h2>
		<p class="tool-lede">Recent messages available in the email bucket.</p>
	</div>
	<div id="loading" class="tool-status p-4 text-center text-sm" aria-live="polite" role="status">
		Loading emails…
	</div>
	<div
		id="error"
		class="rounded border border-red-300 bg-red-50 p-4 text-center text-sm text-red-800 dark:border-red-800 dark:bg-red-900/20 dark:text-red-300"
		style="display: none"
	>
	</div>
	<div class="overflow-x-auto rounded-lg border border-[var(--tool-line)]">
		<table class="min-w-full border-collapse">
			<thead class="bg-[color-mix(in_oklab,var(--tool-paper)_86%,var(--tool-line))]">
				<tr>
					<th
						class="px-4 py-3 text-left text-[11px] font-medium tracking-[0.22em] text-[var(--tool-muted)] uppercase md:px-6"
					>
						Name
					</th>
					<th
						class="px-4 py-3 text-left text-[11px] font-medium tracking-[0.22em] text-[var(--tool-muted)] uppercase md:px-6"
					>
						Size
					</th>
					<th
						class="px-4 py-3 text-left text-[11px] font-medium tracking-[0.22em] text-[var(--tool-muted)] uppercase md:px-6"
					>
						Uploaded
					</th>
					<th
						class="px-4 py-3 text-left text-[11px] font-medium tracking-[0.22em] text-[var(--tool-muted)] uppercase md:px-6"
					>
						Type
					</th>
					<th
						class="px-4 py-3 text-left text-[11px] font-medium tracking-[0.22em] text-[var(--tool-muted)] uppercase md:px-6"
					>
						From
					</th>
					<th
						class="px-4 py-3 text-left text-[11px] font-medium tracking-[0.22em] text-[var(--tool-muted)] uppercase md:px-6"
					>
						To
					</th>
					<th
						class="px-4 py-3 text-left text-[11px] font-medium tracking-[0.22em] text-[var(--tool-muted)] uppercase md:px-6"
					>
						Subject
					</th>
				</tr>
			</thead>
			<tbody></tbody>
		</table>
	</div>
</div>
