---
import type { HTMLTag, Polymorphic } from "astro/types";
import FormattedDate from "@/components/FormattedDate.astro";
import type { Note, NoteAttachment } from "@/lib/ap/types";

type Props<Tag extends HTMLTag> = Polymorphic<{ as: Tag }> & {
	note: Note;
	/**
	 * Pre-rendered HTML for the note's `content` (markdown → HTML). The SSR
	 * pages render the markdown once and pass the HTML here rather than
	 * having the component depend on a markdown pipeline.
	 */
	html: string;
	/** Media attachments (e.g. channel-post photos) rendered below the content. */
	attachments?: NoteAttachment[] | undefined;
	isPreview?: boolean | undefined;
};

const { as: Tag = "div", note, html, attachments = [], isPreview = false } = Astro.props;
---

<article
	class:list={[isPreview && "bg-global-text/5 inline-grid rounded-md px-4 py-3"]}
	data-pagefind-body={isPreview ? false : true}
>
	<Tag class="title" class:list={{ "text-base": isPreview }}>
		{
			isPreview ? (
				note.title ? (
					<a class="cactus-link" href={`/notes/${note.id}/`}>
						{note.title}
					</a>
				) : (
					<a class="cactus-link" href={`/notes/${note.id}/`}>
						<FormattedDate
							dateTimeOptions={{
								hour: "2-digit",
								minute: "2-digit",
								year: "2-digit",
								month: "2-digit",
								day: "2-digit",
							}}
							date={note.publishDate}
						/>
					</a>
				)
			) : (
				<>{note.title}</>
			)
		}
	</Tag>
	<FormattedDate
		dateTimeOptions={{
			hour: "2-digit",
			minute: "2-digit",
			year: "2-digit",
			month: "2-digit",
			day: "2-digit",
		}}
		date={note.publishDate}
	/>
	<div
		class="prose prose-sm prose-cactus mt-4 max-w-none [&>p:last-of-type]:mb-0"
		class:list={{ "line-clamp-6": isPreview }}
		set:html={html}
	/>
	{
		!isPreview && attachments.length > 0 && (
			<div class="mt-4 flex flex-col gap-3">
				{attachments.map((attachment: NoteAttachment) => (
					<img
						class="max-w-full rounded-md"
						src={attachment.url}
						alt={attachment.name ?? ""}
						width={attachment.width ?? undefined}
						height={attachment.height ?? undefined}
						loading="lazy"
						decoding="async"
					/>
				))}
			</div>
		)
	}
</article>
