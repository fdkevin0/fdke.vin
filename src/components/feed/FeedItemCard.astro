---
export interface Props {
	url: string;
	feedTitle?: string;
	publishedAt: string | null;
	sourceLanguage: string | null;
	title: string;
	titleEn: string | null;
	summary: string | null;
	summaryEn: string | null;
	rank?: number;
	showRank?: boolean;
}

const {
	url,
	feedTitle,
	publishedAt,
	sourceLanguage,
	title,
	titleEn,
	summary,
	summaryEn,
	rank,
	showRank = false,
} = Astro.props;

const hasOriginalLanguage = sourceLanguage && sourceLanguage.toLowerCase() !== "en";
const defaultTitle = titleEn || title;
const defaultSummary = summaryEn || summary || "";
const originalTitle = hasOriginalLanguage ? title : defaultTitle;
const originalSummary = hasOriginalLanguage ? summary : defaultSummary;
---

<feed-item-card class="block">
	<article
		class="rounded border border-zinc-200 bg-white p-5 transition-colors hover:border-zinc-400 dark:border-zinc-800 dark:bg-zinc-950 dark:hover:border-zinc-600"
	>
		<div class="flex flex-col gap-3">
			<div class="flex items-start justify-between gap-3">
				<div class="min-w-0 flex-1 space-y-1">
					{
						showRank && rank ? (
							<p class="text-[11px] tracking-[0.22em] text-zinc-500 uppercase dark:text-zinc-400">
								No. {rank} {feedTitle ? `• ${feedTitle}` : ""}
							</p>
						) : feedTitle ? (
							<p class="text-[11px] tracking-[0.22em] text-zinc-500 uppercase dark:text-zinc-400">
								{feedTitle}
							</p>
						) : null
					}
					<h2
						class="{compact ? 'text-sm' : 'text-lg'} text-base font-semibold text-zinc-900 dark:text-zinc-100"
					>
						<a
							href={url}
							target="_blank"
							rel="noopener noreferrer"
							class="line-clamp-2 hover:underline"
						>
							<span data-title-en>{defaultTitle}</span>
							<span data-title-original class="hidden">{originalTitle}</span>
						</a>
					</h2>
				</div>
				{
					hasOriginalLanguage && (
						<button
							type="button"
							data-lang-toggle
							class="shrink-0 rounded border border-zinc-300 px-2.5 py-1.5 text-xs tracking-[0.18em] uppercase transition hover:bg-zinc-50 dark:border-zinc-700 dark:hover:bg-zinc-800"
							title="Toggle language"
						>
							<span data-lang-label>{sourceLanguage?.toUpperCase()}</span>
						</button>
					)
				}
			</div>

			<div class="space-y-2">
				<p class="line-clamp-3 text-sm leading-relaxed text-zinc-600 dark:text-zinc-300">
					<span data-summary-en>{defaultSummary}</span>
					<span data-summary-original class="hidden">{originalSummary}</span>
				</p>
			</div>

			<div class="flex items-center gap-3 text-xs text-zinc-500 dark:text-zinc-400">
				<time datetime={publishedAt ?? undefined}>
					{
						publishedAt
							? new Date(publishedAt).toLocaleDateString(undefined, {
									day: "numeric",
									month: "short",
									year: "numeric",
								})
							: "Date unavailable"
					}
				</time>
				{hasOriginalLanguage && <span>•</span>}
				{
					hasOriginalLanguage && (
						<span class="text-[11px] tracking-[0.18em] uppercase">{sourceLanguage}</span>
					)
				}
			</div>

			<div class="pt-2">
				<a
					href={url}
					target="_blank"
					rel="noopener noreferrer"
					class="inline-flex items-center rounded border border-zinc-300 px-3 py-1.5 text-xs tracking-[0.18em] uppercase transition hover:bg-zinc-50 dark:border-zinc-700 dark:hover:bg-zinc-800"
				>
					Read
				</a>
			</div>
		</div>
	</article>
</feed-item-card>

<script>
	class FeedItemCardElement extends HTMLElement {
		#isEnglish = true;

		connectedCallback() {
			const toggleButton = this.querySelector("[data-lang-toggle]");
			if (!toggleButton) return;

			const titleEn = this.querySelector("[data-title-en]");
			const titleOriginal = this.querySelector("[data-title-original]");
			const summaryEn = this.querySelector("[data-summary-en]");
			const summaryOriginal = this.querySelector("[data-summary-original]");
			const langLabel = this.querySelector("[data-lang-label]");

			if (!titleEn || !titleOriginal || !summaryEn || !summaryOriginal || !langLabel) return;

			toggleButton.addEventListener("click", () => {
				this.#isEnglish = !this.#isEnglish;

				if (this.#isEnglish) {
					titleEn.classList.remove("hidden");
					titleOriginal.classList.add("hidden");
					summaryEn.classList.remove("hidden");
					summaryOriginal.classList.add("hidden");
				} else {
					titleEn.classList.add("hidden");
					titleOriginal.classList.remove("hidden");
					summaryEn.classList.add("hidden");
					summaryOriginal.classList.remove("hidden");
				}
			});
		}
	}

	if (!customElements.get("feed-item-card")) {
		customElements.define("feed-item-card", FeedItemCardElement);
	}
</script>
