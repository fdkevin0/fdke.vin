<hyperfocal-calculator class="block">
	<div class="grid gap-4 md:grid-cols-[minmax(0,1.1fr)_minmax(18rem,0.9fr)]">
		<form class="tool-panel space-y-4" data-hyperfocal-form>
			<div class="grid gap-4 sm:grid-cols-2">
				<label class="space-y-2">
					<span class="tool-field-label">Focal Length</span>
					<input
						class="tool-input"
						autocomplete="off"
						inputmode="decimal"
						min="1"
						name="focal-length"
						step="0.1"
						type="number"
						value="35"
					/>
				</label>
				<label class="space-y-2">
					<span class="tool-field-label">Aperture</span>
					<input
						class="tool-input"
						autocomplete="off"
						inputmode="decimal"
						min="0.7"
						name="aperture"
						step="0.1"
						type="number"
						value="8"
					/>
				</label>
			</div>
			<div class="grid gap-4 sm:grid-cols-[minmax(0,1fr)_minmax(0,0.7fr)]">
				<label class="space-y-2">
					<span class="tool-field-label">Sensor Format</span>
					<select class="tool-select" autocomplete="off" name="sensor-preset">
						<option value="0.030">Full frame (0.030 mm CoC)</option>
						<option value="0.020">APS-C / Super 35 (0.020 mm CoC)</option>
						<option value="0.015">Micro Four Thirds (0.015 mm CoC)</option>
						<option value="0.011">1-inch sensor (0.011 mm CoC)</option>
						<option value="custom">Custom CoC</option>
					</select>
				</label>
				<label class="space-y-2">
					<span class="tool-field-label">CoC (mm)</span>
					<input
						class="tool-input"
						autocomplete="off"
						inputmode="decimal"
						min="0.001"
						name="coc"
						step="0.001"
						type="number"
						value="0.030"
					/>
					<p class="tool-lede text-xs">
						Circle of Confusion is the largest blur spot that still looks acceptably sharp in the
						final image. Smaller sensors usually use a smaller CoC value.
					</p>
				</label>
			</div>
		</form>

		<div class="tool-panel space-y-4">
			<div>
				<p class="tool-field-label">Hyperfocal Distance</p>
				<p class="tool-readout mt-3" data-output>5.14 m</p>
				<p class="tool-lede mt-3" data-summary>
					With a 35 mm lens at f/8 on full frame, focus at 5.14 m to keep depth of field extending
					from roughly half that distance to infinity.
				</p>
			</div>
			<div class="tool-status p-3 text-xs leading-relaxed">
				<p>H = f² / (N × c) + f</p>
				<p class="mt-2">
					`f` is focal length in mm, `N` is the f-number, and `c` is the circle of confusion in mm.
				</p>
			</div>
		</div>
	</div>
</hyperfocal-calculator>

<script>
	import { formatDistance, hyperfocalDistance } from "@/lib/tools/optics";

	class HyperfocalCalculatorElement extends HTMLElement {
		connectedCallback() {
			const form = this.querySelector("[data-hyperfocal-form]") as HTMLFormElement | null;
			const focalLengthInput = this.querySelector(
				'input[name="focal-length"]',
			) as HTMLInputElement | null;
			const apertureInput = this.querySelector('input[name="aperture"]') as HTMLInputElement | null;
			const cocInput = this.querySelector('input[name="coc"]') as HTMLInputElement | null;
			const sensorPresetInput = this.querySelector(
				'select[name="sensor-preset"]',
			) as HTMLSelectElement | null;
			const output = this.querySelector("[data-output]") as HTMLElement | null;
			const summary = this.querySelector("[data-summary]") as HTMLElement | null;

			if (
				!form ||
				!focalLengthInput ||
				!apertureInput ||
				!cocInput ||
				!sensorPresetInput ||
				!output ||
				!summary
			) {
				return;
			}

			const syncPreset = () => {
				if (sensorPresetInput.value !== "custom") {
					cocInput.value = sensorPresetInput.value;
				}
			};

			const update = () => {
				const focalLength = Number(focalLengthInput.value);
				const aperture = Number(apertureInput.value);
				const coc = Number(cocInput.value);
				const result = hyperfocalDistance(focalLength, aperture, coc);

				if (!result) {
					output.textContent = "Invalid input";
					summary.textContent = "Enter positive values for focal length, aperture, and CoC.";
					return;
				}

				output.textContent = formatDistance(result.distanceMm);
				summary.textContent =
					`With a ${focalLength.toFixed(0)} mm lens at f/${aperture.toFixed(1)}, ` +
					`focus at ${formatDistance(result.distanceMm)} to keep depth of field ` +
					`extending from roughly ${formatDistance(result.nearLimitMm)} to infinity.`;
			};

			sensorPresetInput.addEventListener("change", () => {
				syncPreset();
				update();
			});

			cocInput.addEventListener("input", () => {
				sensorPresetInput.value = "custom";
				update();
			});

			form.addEventListener("input", update);

			syncPreset();
			update();
		}
	}

	customElements.define("hyperfocal-calculator", HyperfocalCalculatorElement);
</script>
