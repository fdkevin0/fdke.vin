---
import { type CollectionEntry, render } from "astro:content";

import Masthead from "@/components/blog/Masthead.astro";
import TOC from "@/components/blog/TOC.astro";
import WebMentions from "@/components/blog/webmentions/index.astro";
import {
	BLOG_LANGS,
	getBlogLangMeta,
	getBlogRssPath,
	hasExplicitBlogLang,
	getPostPath,
} from "@/lib/blog-i18n";
import { getPostTranslationsByLang } from "@/data/post";

import BaseLayout from "./Base.astro";

interface Props {
	post: CollectionEntry<"post">;
}

const { post } = Astro.props;
const { ogImage, title, description, updatedDate, publishDate } = post.data;
const socialImage = ogImage ?? `/og-image/${post.id}.png`;
const articleDate = updatedDate?.toISOString() ?? publishDate.toISOString();
const { headings, remarkPluginFrontmatter } = await render(post);
const readingTime: string = remarkPluginFrontmatter.readingTime;
const translations = await getPostTranslationsByLang(post);
const explicitLang = hasExplicitBlogLang(Astro.url);
const supportedTranslations = BLOG_LANGS.flatMap((lang) => {
	const translatedPost = translations[lang];
	if (!translatedPost) return [];
	return [
		{
			href: getPostPath(translatedPost, true),
			label: getBlogLangMeta(lang).label,
			lang,
		},
	];
});
const alternates = BLOG_LANGS.flatMap((lang) => {
	const translatedPost = translations[lang];
	if (!translatedPost) return [];
	return [
		{
			href: new URL(getPostPath(translatedPost, true), Astro.site).href,
			hreflang: getBlogLangMeta(lang).htmlLang,
		},
	];
});
---

<BaseLayout
	meta={{
		alternates,
		articleDate,
		blogLanguage: post.data.lang,
		description,
		lang: getBlogLangMeta(post.data.lang).htmlLang,
		ogImage: socialImage,
		ogLocale: getBlogLangMeta(post.data.lang).ogLocale,
		rssHref: getBlogRssPath(post.data.lang, explicitLang),
		title,
	}}
>
	<article class="grow break-words" data-pagefind-body>
		<div id="blog-hero" class="mb-12">
			<Masthead content={post} explicitLanguage={explicitLang} readingTime={readingTime} />
		</div>
		<div class="flex flex-col gap-10 lg:flex-row lg:items-start lg:justify-between">
			{(supportedTranslations.length > 1 || headings.length > 0) && (
				<aside class="lg:sticky lg:top-12 lg:order-2 lg:-me-32 lg:basis-64">
					{
						supportedTranslations.length > 1 && (
							<nav class="mb-6" aria-label="Post language">
								<h2 class="title mb-3 text-lg">Language</h2>
								<ul class="flex flex-wrap gap-2">
									{supportedTranslations.map((translation) => (
										<li>
											<a
												class:list={[
													"rounded border px-2 py-1 text-xs transition-colors sm:text-sm",
													translation.lang === post.data.lang
														? "border-accent bg-accent/10 text-accent"
														: "hover:border-accent hover:text-accent border-zinc-300 dark:border-zinc-700",
												]}
												href={translation.href}
											>
												{translation.label}
											</a>
										</li>
									))}
								</ul>
							</nav>
						)
					}
					{!!headings.length && <TOC headings={headings} />}
				</aside>
			)}
			<div
				class="prose prose-sm prose-headings:font-semibold prose-headings:text-accent-2 prose-headings:before:absolute prose-headings:before:-ms-4 prose-headings:before:text-gray-600 prose-headings:hover:before:text-accent sm:prose-headings:before:content-['#'] sm:prose-th:before:content-none"
			>
				<slot />
				<WebMentions />
			</div>
		</div>
	</article>
	<button
		class="hover:border-link fixed end-4 bottom-8 z-90 flex h-10 w-10 translate-y-28 cursor-pointer items-center justify-center rounded-full border-2 border-transparent bg-zinc-200 text-3xl opacity-0 transition-all transition-discrete duration-300 data-[show=true]:translate-y-0 data-[show=true]:opacity-100 sm:end-8 sm:h-12 sm:w-12 dark:bg-zinc-700"
		data-show="false"
		id="to-top-btn"
	>
		<span class="sr-only">Back to top</span>
		<svg
			aria-hidden="true"
			class="h-6 w-6"
			fill="none"
			focusable="false"
			stroke="currentColor"
			stroke-width="2"
			viewBox="0 0 24 24"
			xmlns="http://www.w3.org/2000/svg"
		>
			<path d="M4.5 15.75l7.5-7.5 7.5 7.5" stroke-linecap="round" stroke-linejoin="round"></path>
		</svg>
	</button>
</BaseLayout>

<script>
	const scrollBtn = document.getElementById("to-top-btn") as HTMLButtonElement;
	const targetHeader = document.getElementById("blog-hero") as HTMLDivElement;

	function callback(entries: IntersectionObserverEntry[]) {
		entries.forEach((entry) => {
			// only show the scroll to top button when the heading is out of view
			scrollBtn.dataset.show = (!entry.isIntersecting).toString();
		});
	}

	scrollBtn.addEventListener("click", () => {
		document.documentElement.scrollTo({ behavior: "smooth", top: 0 });
	});

	const observer = new IntersectionObserver(callback);
	observer.observe(targetHeader);
</script>
