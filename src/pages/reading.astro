---
import Layout from "@/layouts/Base.astro";
---

<Layout
	meta={{
		title: "Reading",
		description:
			"A rolling reading list of feed posts that stay visible for 24 hours, extended for another 24 hours whenever you open them.",
	}}
>
	<section class="space-y-8">
		<div class="flex items-center justify-between gap-4">
			<h1 class="title text-2xl md:text-3xl">Reading</h1>
			<button
				id="reading-refresh"
				type="button"
				class="inline-flex shrink-0 items-center rounded border border-zinc-300 px-3 py-1.5 text-xs tracking-[0.18em] uppercase transition hover:bg-zinc-50 disabled:cursor-not-allowed disabled:opacity-60 dark:border-zinc-700 dark:hover:bg-zinc-800"
			>
				Refresh
			</button>
		</div>

		<div id="reading-feedback" class="hidden rounded border px-4 py-3 text-sm"></div>

		<div id="reading-tabs" class="hidden flex-wrap gap-2"></div>

		<div
			id="reading-loading"
			class="rounded border border-dashed border-zinc-200 p-5 text-sm text-zinc-600 dark:border-zinc-800 dark:text-zinc-300"
		>
			Loading reading list...
		</div>

		<div
			id="reading-empty"
			class="hidden rounded border border-dashed border-zinc-200 p-5 text-sm text-zinc-600 dark:border-zinc-800 dark:text-zinc-300"
		>
			No posts are currently in the reading window.
		</div>

		<div id="reading-list" class="grid gap-4"></div>
	</section>

	<script is:inline>
		const readingList = document.getElementById("reading-list");
		const readingLoading = document.getElementById("reading-loading");
		const readingEmpty = document.getElementById("reading-empty");
		const readingFeedback = document.getElementById("reading-feedback");
		const readingTabs = document.getElementById("reading-tabs");
		const readingRefresh = document.getElementById("reading-refresh");
		let allItems = [];
		let selectedFeedId = "";
		let isLoadingReading = false;

		function escapeHtml(value) {
			return String(value)
				.replaceAll("&", "&amp;")
				.replaceAll("<", "&lt;")
				.replaceAll(">", "&gt;")
				.replaceAll('"', "&quot;");
		}

		function getFilteredItems() {
			if (!selectedFeedId) return allItems;
			return allItems.filter((item) => item.feedId === selectedFeedId);
		}

		function setError(message) {
			if (!readingFeedback) return;
			readingFeedback.textContent = message;
			readingFeedback.className =
				"rounded border border-red-300 bg-red-50 px-4 py-3 text-sm text-red-800 dark:border-red-800 dark:bg-red-900/20 dark:text-red-300";
			readingFeedback.classList.remove("hidden");
		}

		function clearError() {
			readingFeedback?.classList.add("hidden");
		}

		function updateRefreshButton() {
			if (!(readingRefresh instanceof HTMLButtonElement)) return;
			readingRefresh.disabled = isLoadingReading;
			readingRefresh.textContent = isLoadingReading ? "Refreshing..." : "Refresh";
		}

		function updateLocalReadingItem(itemId, updater) {
			const item = allItems.find((entry) => entry.itemId === itemId);
			if (!item) return;
			updater(item);
			renderReading();
		}

		function renderTabs(items) {
			if (!readingTabs) return;

			const feeds = Array.from(
				new Map(items.map((item) => [item.feedId, { id: item.feedId, title: item.feedTitle }])).values(),
			);

			if (feeds.length <= 1) {
				readingTabs.classList.add("hidden");
				readingTabs.innerHTML = "";
				return;
			}

			const tabs = [{ id: "", title: "All" }, ...feeds];
			readingTabs.innerHTML = tabs
				.map((tab) => {
					const isActive = tab.id === selectedFeedId;
					const className = isActive
						? "border-zinc-900 bg-zinc-900 text-white dark:border-zinc-100 dark:bg-zinc-100 dark:text-zinc-950"
						: "border-zinc-300 bg-white text-zinc-700 hover:bg-zinc-50 dark:border-zinc-700 dark:bg-zinc-950 dark:text-zinc-300 dark:hover:bg-zinc-900";

					return `<button type="button" data-feed-tab="${escapeHtml(tab.id)}" class="rounded-full border px-3 py-1.5 text-xs tracking-[0.14em] uppercase transition ${className}">
						${escapeHtml(tab.title)}
					</button>`;
				})
				.join("");
			readingTabs.classList.remove("hidden");
		}

		function renderItems(items) {
			if (!readingList || !readingEmpty) return;
			readingEmpty.textContent = selectedFeedId
				? "No posts are currently visible for the selected feed."
				: "No posts are currently in the reading window.";
			readingEmpty.style.display = items.length ? "none" : "block";
			readingList.innerHTML = items
				.map(
					(item) => {
						const hasOriginalLanguage = item.sourceLanguage && item.sourceLanguage.toLowerCase() !== "en";
						const defaultTitle = item.titleEn || item.title;
						const defaultDescription = item.descriptionEn || item.description || "";
						const originalTitle = hasOriginalLanguage ? item.title : defaultTitle;
						const originalDescription = hasOriginalLanguage ? item.description : defaultDescription;
						const pubDate = item.publishedAt
							? new Date(item.publishedAt).toLocaleDateString(undefined, {
									day: "numeric",
									month: "short",
									year: "numeric",
								})
							: "Date unavailable";

						return `<feed-item-card class="block">
							<article data-item-id="${escapeHtml(item.itemId)}" class="rounded border border-zinc-200 bg-white p-5 transition-colors hover:border-zinc-400 dark:border-zinc-800 dark:bg-zinc-950 dark:hover:border-zinc-600">
								<div class="flex flex-col gap-3">
									<div class="flex items-start justify-between gap-3">
										<div class="min-w-0 flex-1 space-y-1">
											<p class="text-[11px] tracking-[0.22em] text-zinc-500 uppercase dark:text-zinc-400">${escapeHtml(item.feedTitle)}</p>
											<h2 class="text-lg font-semibold text-zinc-900 dark:text-zinc-100">
												<a href="${escapeHtml(item.url)}" target="_blank" rel="noopener noreferrer" data-reading-open class="hover:underline line-clamp-2">
													<span data-title-en>${escapeHtml(defaultTitle)}</span>
													<span data-title-original class="hidden">${escapeHtml(originalTitle)}</span>
												</a>
											</h2>
										</div>
										${hasOriginalLanguage ? `<button type="button" data-lang-toggle data-original-language="${escapeHtml(item.sourceLanguage.toUpperCase())}" class="shrink-0 rounded border border-zinc-300 px-2.5 py-1.5 text-xs tracking-[0.18em] uppercase transition hover:bg-zinc-50 dark:border-zinc-700 dark:hover:bg-zinc-800" title="Show ${escapeHtml(item.sourceLanguage.toUpperCase())}">
											<span data-lang-label>${escapeHtml(item.sourceLanguage.toUpperCase())}</span>
										</button>` : ""}
									</div>
									<div class="space-y-2">
										<p class="text-sm leading-relaxed text-zinc-600 dark:text-zinc-300 line-clamp-3">
											<span data-desc-en>${escapeHtml(defaultDescription)}</span>
											<span data-desc-original class="hidden">${escapeHtml(originalDescription)}</span>
										</p>
									</div>
									<div class="flex items-center gap-3 text-xs text-zinc-500 dark:text-zinc-400">
										<time>Published ${pubDate}</time>
										<span>•</span>
										<span><span data-click-count>${escapeHtml(item.clickCount)}</span> clicks</span>
										${hasOriginalLanguage ? "<span>•</span>" : ""}
										${hasOriginalLanguage ? `<span class="text-[11px] tracking-[0.18em] uppercase">${escapeHtml(item.sourceLanguage)}</span>` : ""}
									</div>
									<div class="pt-2">
										<a href="${escapeHtml(item.url)}" target="_blank" rel="noopener noreferrer" data-reading-open class="inline-flex items-center rounded border border-zinc-300 px-3 py-1.5 text-xs tracking-[0.18em] uppercase transition hover:bg-zinc-50 dark:border-zinc-700 dark:hover:bg-zinc-800">
											Read
										</a>
									</div>
								</div>
							</article>
						</feed-item-card>`;
					},
				)
				.join("");
		}

		function renderReading() {
			renderTabs(allItems);
			renderItems(getFilteredItems());
		}

		async function loadReading() {
			isLoadingReading = true;
			updateRefreshButton();
			try {
				clearError();
				const response = await fetch("/api/reading", { headers: { Accept: "application/json" } });
				const data = await response.json();
				if (!response.ok) {
					throw new Error(data.error || "Failed to load reading");
				}
				allItems = Array.isArray(data.items) ? data.items : [];
				renderReading();
			} catch (error) {
				setError(error instanceof Error ? error.message : "Failed to load reading");
			} finally {
				isLoadingReading = false;
				updateRefreshButton();
				readingLoading?.remove();
			}
		}

		void loadReading();

		readingTabs?.addEventListener("click", (event) => {
			const target = event.target instanceof Element ? event.target.closest("[data-feed-tab]") : null;
			if (!target) return;
			selectedFeedId = target.getAttribute("data-feed-tab") || "";
			renderReading();
		});

		readingRefresh?.addEventListener("click", () => {
			void loadReading();
		});

		function markReadingItemOpened(itemId) {
			const currentItem = allItems.find((entry) => entry.itemId === itemId);
			if (!currentItem) return;

			const previousClickCount = Number(currentItem.clickCount || 0);
			const optimisticVisibleUntil = new Date(Date.now() + 24 * 60 * 60 * 1000).toISOString();
			updateLocalReadingItem(itemId, (item) => {
				item.clickCount = previousClickCount + 1;
				item.visibleUntil = optimisticVisibleUntil;
			});

			const body = JSON.stringify({ itemId });
			void fetch("/api/reading/click", {
				method: "POST",
				headers: {
					"Content-Type": "application/json",
					Accept: "application/json",
				},
				body,
				keepalive: true,
			})
				.then(async (response) => {
					const data = await response.json().catch(() => null);
					if (!response.ok) {
						throw new Error(data?.error || "Failed to extend reading item visibility");
					}

					updateLocalReadingItem(itemId, (item) => {
						item.clickCount = Number(data?.clickCount ?? item.clickCount);
						item.visibleUntil = data?.visibleUntil || item.visibleUntil;
					});
				})
				.catch(() => {
					updateLocalReadingItem(itemId, (item) => {
						item.clickCount = previousClickCount;
					});
				});
		}

		class FeedItemCardElement extends HTMLElement {
			#isEnglish = true;

			connectedCallback() {
				const toggleButton = this.querySelector("[data-lang-toggle]");
				const itemId = this.querySelector("[data-item-id]")?.getAttribute("data-item-id");
				const openLinks = this.querySelectorAll("[data-reading-open]");
				const titleEn = this.querySelector("[data-title-en]");
				const titleOriginal = this.querySelector("[data-title-original]");
				const descEn = this.querySelector("[data-desc-en]");
				const descOriginal = this.querySelector("[data-desc-original]");
				const langLabel = this.querySelector("[data-lang-label]");
				const originalLanguage = toggleButton?.getAttribute("data-original-language") || "";

				if (toggleButton && titleEn && titleOriginal && descEn && descOriginal && langLabel) {
					toggleButton.addEventListener("click", () => {
						this.#isEnglish = !this.#isEnglish;

						if (this.#isEnglish) {
							titleEn.classList.remove("hidden");
							titleOriginal.classList.add("hidden");
							descEn.classList.remove("hidden");
							descOriginal.classList.add("hidden");
							langLabel.textContent = originalLanguage;
							toggleButton.setAttribute("title", `Show ${originalLanguage}`);
						} else {
							titleEn.classList.add("hidden");
							titleOriginal.classList.remove("hidden");
							descEn.classList.add("hidden");
							descOriginal.classList.remove("hidden");
							langLabel.textContent = "EN";
							toggleButton.setAttribute("title", "Show EN");
						}
					});
				}

				if (itemId) {
					for (const link of openLinks) {
						link.addEventListener("click", () => {
							markReadingItemOpened(itemId);
						});
					}
				}
			}
		}

		if (!customElements.get("feed-item-card")) {
			customElements.define("feed-item-card", FeedItemCardElement);
		}
	</script>
</Layout>
