---
import PageLayout from "@/layouts/Base.astro";

const meta = {
	description:
		"About FDKevin: software engineer building useful tools, web experiments, and photography utilities.",
	title: "About",
};
---

<PageLayout meta={meta}>
	<h1 class="title mb-12">About</h1>
	<div class="prose prose-sm prose-cactus max-w-none">
		<p>
			I’m FDKevin, a software engineer from China. I build small useful tools, work with LLM agents,
			and spend a lot of time on photography.
		</p>
		<p>
			You can find me online as <code>fdkevin</code>, <code>FDKevin</code>, <code>fdkevin0</code>,
			and <code>fdkevinzero</code>.
		</p>
		<p>One formula for spelling my name:</p>
		<p>
			<code>fd + kevin = fdkevin</code>
		</p>
		<p>Short version: <code>fd</code> + <code>kevin</code>.</p>
	</div>
</PageLayout>
