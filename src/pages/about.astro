---
import PageLayout from "@/layouts/Base.astro";

const meta = {
	description: "About fdkevin: MSc Computer Science student at the University of Glasgow.",
	title: "About",
};
---

<PageLayout meta={meta}>
	<h1 class="title mb-12">About</h1>
	<div class="prose prose-sm prose-cactus max-w-none">
		<p>
			I’m fdkevin, an MSc Computer Science student at the University of Glasgow. I like building
			small useful tools, working with LLM agents, and spending time on photography.
		</p>
		<p>Some projects and tools I maintain:</p>
		<ul class="list-inside list-disc" role="list">
			<li>
				<a
					class="cactus-link inline-block"
					href="/exchange/">CNY BOC exchange rate monitor</a
				>
			</li>
			<li>
				<a
					class="cactus-link inline-block"
					href="/camera/">Camera hyperfocal distance and equivalent focal length calculator</a
				>
			</li>
			<li>LLM Agent Mob (Telegram Bot)</li>
		</ul>
		<p>
			You can find me online as <code>fdkevin</code>, <code>FDKevin</code>, <code>fdkevin0</code>,
			and <code>fdkevinzero</code>.
		</p>
		<p>One formula for spelling my name:</p>
		<p>
			<code>fd + kevin = fdkevin</code>
		</p>
		<p>Short version: <code>fd</code> + <code>kevin</code>.</p>
	</div>
</PageLayout>
