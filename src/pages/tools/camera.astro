---
import EquivalentFocalLengthCalculator from "@/components/EquivalentFocalLengthCalculator.astro";
import HyperfocalCalculator from "@/components/HyperfocalCalculator.astro";
import PageLayout from "@/layouts/Base.astro";
---

<PageLayout
	meta={{
		title: "Camera",
		description:
			"Quick camera calculator for hyperfocal distance and equivalent focal lengths across sensor formats.",
	}}
>
	<section class="space-y-6">
		<div class="space-y-3">
			<p class="text-[11px] tracking-[0.42em] text-zinc-500 uppercase dark:text-zinc-400">
				<a href="/tools/" class="hover:underline">Tools</a> / Camera
			</p>
			<h1 class="title text-2xl">Camera</h1>
			<p class="text-sm leading-relaxed text-zinc-600 dark:text-zinc-300">
				Use the camera tools to estimate hyperfocal distance for broad depth of field and
				convert equivalent focal lengths across different sensor formats.
			</p>
		</div>
		<HyperfocalCalculator />
		<EquivalentFocalLengthCalculator />
	</section>
</PageLayout>
