---
import EquivalentFocalLengthCalculator from "@/components/EquivalentFocalLengthCalculator.astro";
import HyperfocalCalculator from "@/components/HyperfocalCalculator.astro";
import PageLayout from "@/layouts/Base.astro";
---

<PageLayout
	meta={{
		title: "Camera",
		description:
			"Quick camera calculator for hyperfocal distance and equivalent focal lengths across sensor formats.",
	}}
>
	<section class="tool-workbench space-y-5">
		<div class="tool-hero space-y-4 pt-8">
			<p class="tool-kicker">
				<a href="/tools/" class="hover:underline">Tools</a> / Camera
			</p>
			<h1 class="tool-title">Camera Bench</h1>
			<p class="tool-lede max-w-2xl">
				Estimate focus marks for broad depth of field and translate lens framing between common
				sensor formats.
			</p>
		</div>
		<HyperfocalCalculator />
		<EquivalentFocalLengthCalculator />
	</section>
</PageLayout>
