---
import ExchangeRates from "@/components/ExchangeRates.astro";
import PageLayout from "@/layouts/Base.astro";
---

<PageLayout meta={{ title: "Exchange Rates" }}>
	<section class="tool-workbench space-y-5">
		<div class="tool-hero space-y-4 pt-8">
			<p class="tool-kicker">
				<a href="/tools/" class="hover:underline">Tools</a> / Exchange
			</p>
			<h1 class="tool-title">Exchange Board</h1>
			<p class="tool-lede max-w-2xl">
				Switch symbols and read the latest buy, sell, cash, and middle rates in one compact board.
			</p>
		</div>
		<ExchangeRates defaultCurrency="USD" limit={12} />
	</section>
</PageLayout>
