---
import { env } from "cloudflare:workers";
import { Code } from "astro-expressive-code/components";
import { createRemoteJWKSet, jwtVerify } from "jose";
import PageLayout from "@/layouts/Base.astro";

export const prerender = false;

interface AccessIdentity {
	email: string;
	idp?: Record<string, unknown>;
	geo?: string;
	user_uuid?: string;
	devicePosture?: Record<string, unknown>;
	account_id?: string;
	iat?: number;
	ip?: string;
	auth_status?: string;
	common_name?: string;
	service_token_id?: string;
	service_token_status?: boolean;
	is_warp?: boolean;
	is_gateway?: boolean;
	gateway_account_id?: string;
	device_id?: string;
	version?: number;
	device_sessions?: Array<{
		id: string;
		created_at: string;
		expires_at: string;
	}>;
}

interface JWTClaims {
	aud: string[];
	email: string;
	exp: number;
	iat: number;
	nbf: number;
	iss: string;
	type: string;
	identity_nonce: string;
	sub: string;
	country?: string;
	common_name?: string;
	name?: string;
	uid?: string;
}

const props = await (async () => {
	const teamDomain = env.CLOUDFLARE_TEAM_DOMAIN;
	const policyAud = env.CLOUDFLARE_POLICY_AUD;

	const parseAudienceList = (value: string | string[]): string[] =>
		typeof value === "string"
			? value
					.split(",")
					.map((v) => v.trim())
					.filter(Boolean)
			: value;

	const policyAudList = parseAudienceList(policyAud);

	if (!teamDomain || policyAudList.length === 0) {
		return {
			teamDomain: "",
			claims: null,
			identity: null,
			error: "Cloudflare Access not configured",
		};
	}

	const token =
		Astro.request.headers.get("cf-access-jwt-assertion") ||
		Astro.cookies.get("CF_Authorization")?.value;

	let claims: JWTClaims | null = null;
	let identity: AccessIdentity | null = null;
	let error: string | null = null;

	if (!token) {
		error = "No authentication token found";
	} else {
		try {
			// Re-verify JWT to access full claims for display
			// Middleware already validates, but we need raw claims here
			const JWKS = createRemoteJWKSet(new URL(`${teamDomain}/cdn-cgi/access/certs`));
			const { payload } = await jwtVerify(token, JWKS, {
				issuer: teamDomain,
				audience: policyAudList,
			});
			claims = payload as unknown as JWTClaims;

			try {
				const identityUrl = `${teamDomain}/cdn-cgi/access/get-identity`;
				const identityResponse = await fetch(identityUrl, {
					headers: {
						cookie: `CF_Authorization=${token}`,
					},
				});

				if (identityResponse.ok) {
					const identityData = (await identityResponse.json()) as {
						data?: AccessIdentity;
					};
					if (identityData.data) {
						identity = identityData.data;
					}
				}
			} catch {}
		} catch (err) {
			error = err instanceof Error ? err.message : "Token validation failed";
		}
	}

	return {
		teamDomain,
		claims,
		claimsJson: claims ? JSON.stringify(claims, null, 2) : null,
		identity,
		identityJson: identity ? JSON.stringify(identity, null, 2) : null,
		error,
	};
})();
---

<PageLayout
	meta={{
		title: "Cloudflare Access",
		description: "View your Cloudflare Zero Trust authentication status and JWT claims.",
	}}
>
	<section class="space-y-6">
		<div class="space-y-3">
			<p class="text-[11px] tracking-[0.42em] text-zinc-500 uppercase dark:text-zinc-400">
				<a href="/tools/" class="hover:underline">Tools</a> / Access
			</p>
			<h1 class="title text-2xl">Cloudflare Access</h1>
			<p class="text-sm leading-relaxed text-zinc-600 dark:text-zinc-300">
				Authentication info for Cloudflare Zero Trust. Your session is protected by Cloudflare Access
				JWT validation.
			</p>
		</div>

		{props.error ? (
			<div class="rounded border border-red-300 bg-red-50 p-4 dark:border-red-800 dark:bg-red-900/20">
				<p class="text-sm text-red-800 dark:text-red-300">{props.error}</p>
			</div>
		) : (
			<div class="space-y-6">
				<div class="rounded border border-zinc-200 p-4 dark:border-zinc-800">
					<h2 class="mb-4 text-lg font-semibold">Authentication Status</h2>
					{props.claims && (
						<div class="space-y-3">
							<div class="grid grid-cols-3 gap-2 text-sm">
								<span class="text-zinc-500 dark:text-zinc-400">Email</span>
								<span class="col-span-2 font-mono">{props.claims.email}</span>
							</div>
							{props.claims.common_name && (
								<div class="grid grid-cols-3 gap-2 text-sm">
									<span class="text-zinc-500 dark:text-zinc-400">Name</span>
									<span class="col-span-2 font-mono">{props.claims.common_name}</span>
								</div>
							)}
							{props.identity?.user_uuid && (
								<div class="grid grid-cols-3 gap-2 text-sm">
									<span class="text-zinc-500 dark:text-zinc-400">User UUID</span>
									<span class="col-span-2 font-mono break-all">{props.identity.user_uuid}</span>
								</div>
							)}
							{props.claims.country && (
								<div class="grid grid-cols-3 gap-2 text-sm">
									<span class="text-zinc-500 dark:text-zinc-400">Country</span>
									<span class="col-span-2 font-mono">{props.claims.country}</span>
								</div>
							)}
							{props.identity?.ip && (
								<div class="grid grid-cols-3 gap-2 text-sm">
									<span class="text-zinc-500 dark:text-zinc-400">IP Address</span>
									<span class="col-span-2 font-mono">{props.identity.ip}</span>
								</div>
							)}
							<div class="grid grid-cols-3 gap-2 text-sm">
								<span class="text-zinc-500 dark:text-zinc-400">Issued</span>
								<span class="col-span-2 font-mono">
									{new Date(props.claims.iat * 1000).toLocaleString()}
								</span>
							</div>
							<div class="grid grid-cols-3 gap-2 text-sm">
								<span class="text-zinc-500 dark:text-zinc-400">Expires</span>
								<span class="col-span-2 font-mono">
									{new Date(props.claims.exp * 1000).toLocaleString()}
								</span>
							</div>
							{props.identity?.is_warp && (
								<div class="grid grid-cols-3 gap-2 text-sm">
									<span class="text-zinc-500 dark:text-zinc-400">WARP</span>
									<span class="col-span-2 font-mono">Enabled</span>
								</div>
							)}
							{props.identity?.is_gateway && (
								<div class="grid grid-cols-3 gap-2 text-sm">
									<span class="text-zinc-500 dark:text-zinc-400">Gateway</span>
									<span class="col-span-2 font-mono">Enabled</span>
								</div>
							)}
						</div>
					)}
				</div>

				{props.identity && props.identity.device_sessions && (
					<div class="rounded border border-zinc-200 p-4 dark:border-zinc-800">
						<h2 class="mb-4 text-lg font-semibold">Device Sessions</h2>
						<ul class="space-y-2 text-sm">
							{props.identity.device_sessions.map((session) => (
								<li class="border-b border-zinc-100 pb-2 last:border-0 last:pb-0 dark:border-zinc-800">
									<div class="grid grid-cols-3 gap-2">
										<span class="text-zinc-500 dark:text-zinc-400">Session ID</span>
										<span class="col-span-2 font-mono break-all">{session.id}</span>
									</div>
									<div class="grid grid-cols-3 gap-2">
										<span class="text-zinc-500 dark:text-zinc-400">Created</span>
										<span class="col-span-2 font-mono">
											{new Date(session.created_at).toLocaleString()}
										</span>
									</div>
									<div class="grid grid-cols-3 gap-2">
										<span class="text-zinc-500 dark:text-zinc-400">Expires</span>
										<span class="col-span-2 font-mono">
											{new Date(session.expires_at).toLocaleString()}
										</span>
									</div>
								</li>
							))}
						</ul>
					</div>
				)}

				{props.claims && (
					<details class="rounded border border-zinc-200 p-4 dark:border-zinc-800">
						<summary class="cursor-pointer font-semibold hover:text-zinc-600 dark:hover:text-zinc-300">
							Raw JWT Claims
						</summary>
						<div class="mt-4 overflow-hidden rounded border border-zinc-200 dark:border-zinc-800">
							<Code code={props.claimsJson || "{}"} lang="json" />
						</div>
					</details>
				)}

				{props.identity && (
					<details class="rounded border border-zinc-200 p-4 dark:border-zinc-800">
						<summary class="cursor-pointer font-semibold hover:text-zinc-600 dark:hover:text-zinc-300">
							Full Identity Payload
						</summary>
						<div class="mt-4 overflow-hidden rounded border border-zinc-200 dark:border-zinc-800">
							<Code code={props.identityJson || "{}"} lang="json" />
						</div>
					</details>
				)}

				<div class="flex gap-3">
					<a
						href={`${props.teamDomain}/cdn-cgi/access/logout`}
						class="rounded border border-zinc-300 px-4 py-2 text-sm transition-colors hover:bg-zinc-50 dark:border-zinc-700 dark:hover:bg-zinc-800"
					>
						Logout
					</a>
					<a
						href="https://one.dash.cloudflare.com/"
						target="_blank"
						rel="noopener noreferrer"
						class="rounded border border-zinc-300 px-4 py-2 text-sm transition-colors hover:bg-zinc-50 dark:border-zinc-700 dark:hover:bg-zinc-800"
					>
						Cloudflare One Dashboard
					</a>
				</div>
			</div>
		)}
	</section>
</PageLayout>
