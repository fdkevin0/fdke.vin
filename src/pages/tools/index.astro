---
import PageLayout from "@/layouts/Base.astro";
---

<PageLayout
	meta={{
		title: "Utilities",
		description:
			"Utilities including camera calculators, exchange rate monitors, and email routing.",
	}}
>
	<section class="space-y-6">
		<div class="space-y-3">
			<h1 class="title text-2xl">Utilities</h1>
			<p class="text-sm leading-relaxed text-zinc-600 dark:text-zinc-300">
				Utilities and calculators for photography, finance, and email.
			</p>
		</div>
		<ul class="space-y-4" role="list">
			<li>
				<a
					href="/tools/access/"
					class="block rounded border border-zinc-200 p-4 transition-colors hover:border-zinc-400 dark:border-zinc-800 dark:hover:border-zinc-600"
				>
					<h2 class="mb-1 text-lg font-semibold">Access</h2>
					<p class="text-sm text-zinc-600 dark:text-zinc-400">
						Cloudflare Zero Trust authentication info and JWT claims.
					</p>
				</a>
			</li>
			<li>
				<a
					href="/tools/mail/"
					class="block rounded border border-zinc-200 p-4 transition-colors hover:border-zinc-400 dark:border-zinc-800 dark:hover:border-zinc-600"
				>
					<h2 class="mb-1 text-lg font-semibold">Email</h2>
					<p class="text-sm text-zinc-600 dark:text-zinc-400">
						Cloudflare Email Routing.
					</p>
				</a>
			</li>
			<li>
				<a
					href="/tools/camera/"
					class="block rounded border border-zinc-200 p-4 transition-colors hover:border-zinc-400 dark:border-zinc-800 dark:hover:border-zinc-600"
				>
					<h2 class="mb-1 text-lg font-semibold">Camera</h2>
					<p class="text-sm text-zinc-600 dark:text-zinc-400">
						Hyperfocal distance and equivalent focal length calculator across sensor formats.
					</p>
				</a>
			</li>
			<li>
				<a
					href="/tools/exchange/"
					class="block rounded border border-zinc-200 p-4 transition-colors hover:border-zinc-400 dark:border-zinc-800 dark:hover:border-zinc-600"
				>
					<h2 class="mb-1 text-lg font-semibold">Exchange</h2>
					<p class="text-sm text-zinc-600 dark:text-zinc-400">
						CNY BOC exchange rate monitor with live buy, sell, and middle rates.
					</p>
				</a>
			</li>
		</ul>
	</section>
</PageLayout>
