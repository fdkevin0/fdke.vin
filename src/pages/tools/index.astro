---
import PageLayout from "@/layouts/Base.astro";
---

<PageLayout
	meta={{
		title: "Tools",
		description:
			"Photography and finance utilities including camera calculators and exchange rate monitors.",
	}}
>
	<section class="space-y-6">
		<div class="space-y-3">
			<h1 class="title text-2xl">Tools</h1>
			<p class="text-sm leading-relaxed text-zinc-600 dark:text-zinc-300">
				Utilities and calculators for photography and finance.
			</p>
		</div>
		<ul class="space-y-4" role="list">
			<li>
				<a
					href="/tools/mail/"
					class="block rounded border border-zinc-200 p-4 transition-colors hover:border-zinc-400 dark:border-zinc-800 dark:hover:border-zinc-600"
				>
					<h2 class="mb-1 text-lg font-semibold">Mail</h2>
					<p class="text-sm text-zinc-600 dark:text-zinc-400">
						Cloudflare R2 email storage viewer with GitHub authentication.
					</p>
				</a>
			</li>
			<li>
				<a
					href="/tools/camera/"
					class="block rounded border border-zinc-200 p-4 transition-colors hover:border-zinc-400 dark:border-zinc-800 dark:hover:border-zinc-600"
				>
					<h2 class="mb-1 text-lg font-semibold">Camera</h2>
					<p class="text-sm text-zinc-600 dark:text-zinc-400">
						Hyperfocal distance and equivalent focal length calculator across sensor formats.
					</p>
				</a>
			</li>
			<li>
				<a
					href="/tools/exchange/"
					class="block rounded border border-zinc-200 p-4 transition-colors hover:border-zinc-400 dark:border-zinc-800 dark:hover:border-zinc-600"
				>
					<h2 class="mb-1 text-lg font-semibold">Exchange</h2>
					<p class="text-sm text-zinc-600 dark:text-zinc-400">
						CNY BOC exchange rate monitor with live buy, sell, and middle rates.
					</p>
				</a>
			</li>
		</ul>
	</section>
</PageLayout>
