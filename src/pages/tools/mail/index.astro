---
import EmailList from "@/components/mail/EmailList.astro";
import Layout from "@/layouts/Base.astro";

export const prerender = false;

const user = Astro.locals.user;
---

<Layout
	meta={{
		title: "Email Viewer",
		description: "View emails from Cloudflare R2 storage",
	}}
>
	<section class="tool-workbench space-y-5">
		<div class="tool-hero space-y-4 pt-8">
			<p class="tool-kicker">
				<a href="/tools/" class="hover:underline">Tools</a> / Email
			</p>
			<div class="flex flex-col gap-3 md:flex-row md:items-start md:justify-between">
				<div class="space-y-3">
					<h1 class="tool-title">Email Viewer</h1>
					<p class="tool-lede max-w-2xl">
						Browse routed emails stored in Cloudflare R2 and open the raw message content for
						inspection.
					</p>
				</div>
				{
					user && (
						<div class="tool-status px-3 py-2 text-sm">
							Logged in as <span class="font-medium text-[var(--tool-ink)]">{user.email}</span>
						</div>
					)
				}
			</div>
		</div>

		<div class="tool-panel">
			<EmailList />
		</div>
	</section>
</Layout>
