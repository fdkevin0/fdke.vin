---
import { type CollectionEntry, getCollection } from "astro:content";
import PostPreview from "@/components/blog/PostPreview.astro";
import Note from "@/components/note/Note.astro";
import SocialList from "@/components/SocialList.astro";
import { getPostsByLang } from "@/data/post";
import {
	BLOG_LANGS,
	getBlogLanguageOptions,
	getBlogUrlWithLang,
	getPostsPath,
	getRequestBlogLang,
	hasExplicitBlogLang,
} from "@/lib/blog-i18n";
import PageLayout from "@/layouts/Base.astro";
import { collectionDateSort } from "@/utils/date";

export const prerender = false;

// Posts
const MAX_POSTS = 10;
const blogLang = getRequestBlogLang(Astro.url, Astro.locals.siteDefaultLang);
const explicitLang = hasExplicitBlogLang(Astro.url);
const allPosts = await getPostsByLang(blogLang);
const allPostsByDate = allPosts.sort(collectionDateSort) as CollectionEntry<"post">[];
const latestPosts = allPostsByDate.slice(0, MAX_POSTS);

// Pinned Posts, set to a max of 3;
const MAX_PINNED_POSTS = 3;
const pinnedPosts = allPostsByDate.filter((p) => p.data.pinned).slice(0, MAX_PINNED_POSTS);

// Notes
const MAX_NOTES = 5;
const allNotes = await getCollection("note");
const latestNotes = allNotes
	.sort(collectionDateSort)
	.slice(0, MAX_NOTES) as CollectionEntry<"note">[];
---

<PageLayout
	meta={{
		blogLanguage: blogLang,
		blogLanguageOptions: getBlogLanguageOptions(
			Object.fromEntries(
				BLOG_LANGS.map((lang) => [lang, { href: getBlogUrlWithLang(Astro.url, lang, true) }]),
			),
		).map((option) => ({
			href: option.href,
			label: option.meta.label,
			lang: option.lang,
		})),
		title: "Home",
	}}
>
	<section>
		<h1 class="title mb-12">Hey!</h1>
		<p class="mb-4">
			Hi, I’m FDKevin, a software engineer building practical tools and writing online.
		</p>
		<p class="mb-4">
			Simply, you can call me FDKevin
			<small>/ˌfʌk dɔ:g 'kevin/</small>
			.
		</p>
		<SocialList />
	</section>
	{
		pinnedPosts.length > 0 && (
			<section class="mt-16">
				<h2 class="title mb-6 text-xl">Pinned Posts</h2>
				<ul class="space-y-4" role="list">
					{pinnedPosts.map((p) => (
						<li class="grid gap-1 sm:grid-cols-[auto_1fr]">
							<PostPreview explicitLanguage={explicitLang} post={p} />
						</li>
					))}
				</ul>
			</section>
		)
	}
	<section class="mt-16">
		<h2 class="title text-accent mb-6 text-xl">
			<a href={getPostsPath(blogLang, 1, explicitLang)}>Posts</a>
		</h2>
		{
			latestPosts.length > 0 ? (
				<ul class="space-y-4" role="list">
					{latestPosts.map((p) => (
						<li class="grid gap-1 sm:grid-cols-[auto_1fr]">
							<PostPreview explicitLanguage={explicitLang} post={p} />
						</li>
					))}
				</ul>
			) : (
				<p class="text-sm text-zinc-600 dark:text-zinc-300">No posts published yet.</p>
			)
		}
	</section>
	{
		latestNotes.length > 0 && (
			<section class="mt-16">
				<h2 class="title text-accent mb-6 text-xl">
					<a href="/notes/">Notes</a>
				</h2>
				<ul class="space-y-6" role="list">
					{latestNotes.map((note) => (
						<li>
							<Note note={note} as="h3" isPreview />
						</li>
					))}
				</ul>
			</section>
		)
	}
</PageLayout>
