---
import { render } from "astro:content";
import Pagination from "@/components/Paginator.astro";
import PostPreview from "@/components/blog/PostPreview.astro";
import { getPostsByLang, getTagMeta } from "@/data/post";
import {
	BLOG_LANGS,
	getBlogLanguageOptions,
	getBlogLangMeta,
	getBlogRssPath,
	getRequestBlogLang,
	getTagPath,
	getTagsIndexPath,
	getBlogUrlWithLang,
	hasExplicitBlogLang,
} from "@/lib/blog-i18n";
import PageLayout from "@/layouts/Base.astro";
import { collectionDateSort } from "@/utils/date";

export const prerender = false;

const pageParam = Astro.params.page;
const pageNumber = pageParam ? Number.parseInt(pageParam, 10) : 1;
const { tag } = Astro.params;
const blogLang = getRequestBlogLang(Astro.url, Astro.locals.siteDefaultLang);
const explicitLang = hasExplicitBlogLang(Astro.url);
const allPosts = (await getPostsByLang(blogLang))
	.sort(collectionDateSort)
	.filter((post) => post.data.tags.includes(tag));
const pageSize = 10;
const totalPages = Math.max(1, Math.ceil(allPosts.length / pageSize));

if (pageNumber < 1 || pageNumber > totalPages) {
	return Astro.redirect("/404");
}

const tagMeta = await getTagMeta(tag);
const TagContent = tagMeta ? (await render(tagMeta)).Content : null;
const offset = (pageNumber - 1) * pageSize;
const pagePosts = allPosts.slice(offset, offset + pageSize);
const langMeta = getBlogLangMeta(blogLang);

const meta = {
	blogLanguage: blogLang,
	blogLanguageOptions: getBlogLanguageOptions(
		Object.fromEntries(
			BLOG_LANGS.map((lang) => [lang, { href: getBlogUrlWithLang(Astro.url, lang) }]),
		),
	).map((option) => ({
		href: option.href,
		label: option.meta.label,
		lang: option.lang,
	})),
	description: tagMeta?.data.description ?? `View all posts with the tag - ${tag}`,
	lang: langMeta.htmlLang,
	ogLocale: langMeta.ogLocale,
	rssHref: getBlogRssPath(blogLang, explicitLang),
	title: tagMeta?.data.title ?? `Posts about ${tag}`,
};

const paginationProps = {
	...(pageNumber > 1 && {
		prevUrl: {
			text: "← Previous Tags",
			url: getTagPath(tag, blogLang, pageNumber - 1, explicitLang),
		},
	}),
	...(pageNumber < totalPages && {
		nextUrl: {
			text: "Next Tags →",
			url: getTagPath(tag, blogLang, pageNumber + 1, explicitLang),
		},
	}),
};
---

<PageLayout meta={meta}>
	<nav class="mb-8" aria-label="Breadcrumbs">
		<ul class="flex items-center">
			<li class="flex items-center">
				<a class="text-accent" href={getTagsIndexPath(blogLang, explicitLang)}>Tags</a>
				<span class="mx-1.5">/</span>
			</li>
			<li aria-current="page"><span aria-hidden="true">#</span>{tag}</li>
		</ul>
	</nav>
	<h1 class="title capitalize">{tagMeta?.data.title ?? `Posts about ${tag}`}</h1>
	<div class="prose prose-sm prose-cactus mb-16 max-w-none">
		{tagMeta?.data.description && <p>{tagMeta.data.description}</p>}
		{TagContent && <TagContent />}
	</div>
	<ul class="space-y-4">
		{
			pagePosts.map((p) => (
				<li class="grid gap-1 sm:grid-cols-[auto_1fr]">
					<PostPreview as="h2" explicitLanguage={explicitLang} post={p} />
				</li>
			))
		}
	</ul>
	<Pagination {...paginationProps} />
</PageLayout>
