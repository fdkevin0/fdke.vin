---
import { getPostsByLang, getUniqueTagsWithCount } from "@/data/post";
import {
	BLOG_LANGS,
	getBlogLanguageOptions,
	getBlogLangMeta,
	getBlogRssPath,
	getBlogUrlWithLang,
	hasExplicitBlogLang,
	getRequestBlogLang,
	getTagPath,
} from "@/lib/blog-i18n";
import PageLayout from "@/layouts/Base.astro";

export const prerender = false;

const blogLang = getRequestBlogLang(Astro.url, Astro.locals.siteDefaultLang);
const explicitLang = hasExplicitBlogLang(Astro.url);
const allPosts = await getPostsByLang(blogLang);
const allTags = getUniqueTagsWithCount(allPosts);
const langMeta = getBlogLangMeta(blogLang);

const meta = {
	blogLanguage: blogLang,
	blogLanguageOptions: getBlogLanguageOptions(
		Object.fromEntries(
			BLOG_LANGS.map((lang) => [lang, { href: getBlogUrlWithLang(Astro.url, lang) }]),
		),
	).map((option) => ({
		href: option.href,
		label: option.meta.label,
		lang: option.lang,
	})),
	description: "A list of all the topics I've written about in my posts",
	lang: langMeta.htmlLang,
	ogLocale: langMeta.ogLocale,
	rssHref: getBlogRssPath(blogLang, explicitLang),
	title: "All Tags",
};
---

<PageLayout meta={meta}>
	<h1 class="title mb-6">Tags</h1>
	{
		allTags.length > 0 ? (
			<ul class="space-y-4">
				{allTags.map(([tag, val]) => (
					<li class="flex items-center gap-x-2">
						<a class="cactus-link inline-block" href={getTagPath(tag, blogLang, 1, explicitLang)}>
							&#35;{tag}
						</a>
						<span class="inline-block">
							- {val} Post{val > 1 && "s"}
						</span>
					</li>
				))}
			</ul>
		) : (
			<p class="text-sm text-zinc-600 dark:text-zinc-300">No tags yet.</p>
		)
	}
</PageLayout>
