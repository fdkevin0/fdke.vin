---
import { Code } from "astro-expressive-code/components";
import Layout from "@/layouts/Base.astro";
import { API_SCOPES } from "@/lib/api/tokens/scopes";

export const prerender = false;

const user = Astro.locals.user;
---

<Layout
	meta={{
		title: "Dashboard",
		description: "Private dashboard for managing API tokens for fdke.vin services.",
	}}
>
	<section class="space-y-6">
		<div class="space-y-3">
			<p class="text-[11px] tracking-[0.42em] text-zinc-500 uppercase dark:text-zinc-400">
				Dashboard
			</p>
			<div class="flex flex-col gap-3 md:flex-row md:items-start md:justify-between">
				<div class="space-y-3">
					<h1 class="title text-2xl">Dashboard</h1>
					<p class="text-sm leading-relaxed text-zinc-600 dark:text-zinc-300">
						Private API management for bearer-token access to internal endpoints on `fdke.vin/api/*`.
					</p>
				</div>
				{user && (
					<div class="rounded border border-zinc-200 px-3 py-2 text-sm text-zinc-600 dark:border-zinc-800 dark:text-zinc-300">
						Signed in as <span class="font-medium text-zinc-900 dark:text-zinc-100">{user.email}</span>
					</div>
				)}
			</div>
		</div>

		<div class="space-y-4">
			<div class="rounded border border-zinc-200 p-4 dark:border-zinc-800 md:p-5">
				<div class="flex flex-col gap-3 md:flex-row md:items-start md:justify-between">
					<div class="space-y-1">
						<h2 class="text-lg font-semibold">Dashboard Feed</h2>
						<p class="text-sm text-zinc-600 dark:text-zinc-300">
							Manage the shared RSS feed pool, daily sync pipeline, and recommendations.
						</p>
					</div>
					<a
						href="/dashboard/feed"
						class="rounded border border-zinc-900 bg-zinc-900 px-4 py-2 text-sm text-white transition hover:bg-zinc-700 dark:border-zinc-100 dark:bg-zinc-100 dark:text-zinc-900 dark:hover:bg-zinc-300"
					>
						Open Feed Dashboard
					</a>
				</div>
			</div>

			<div class="rounded border border-zinc-200 p-4 dark:border-zinc-800 md:p-5">
				<div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
					<div class="space-y-1">
						<h2 class="text-lg font-semibold">API Management</h2>
						<p class="text-sm text-zinc-600 dark:text-zinc-300">
							Default scope is `api.ping`. Add more scopes only when needed.
						</p>
					</div>
					<p class="max-w-sm text-xs leading-relaxed text-zinc-500 dark:text-zinc-400">
						Create or rotate a token, then click that token row to auto-fill the curl command.
					</p>
				</div>
				<form id="create-token-form" class="mt-4 space-y-4">
					<label class="block space-y-2 text-sm">
						<span class="text-zinc-700 dark:text-zinc-200">Token name</span>
						<input name="name" required placeholder="Monitoring token" class="w-full rounded border border-zinc-300 bg-white px-3 py-2 text-sm outline-none transition focus:border-zinc-500 dark:border-zinc-700 dark:bg-zinc-900" />
					</label>
					<fieldset class="space-y-2">
						<legend class="text-sm text-zinc-700 dark:text-zinc-200">Scopes</legend>
						<div class="space-y-2">
							{API_SCOPES.map((scope) => (
								<label class="flex items-center gap-3 rounded border border-zinc-200 px-3 py-2 text-sm dark:border-zinc-800">
									<input type="checkbox" name="scopes" value={scope} checked={scope === "api.ping"} />
									<span class="font-mono text-xs">{scope}</span>
								</label>
							))}
						</div>
					</fieldset>
					<label class="block space-y-2 text-sm">
						<span class="text-zinc-700 dark:text-zinc-200">Expire at</span>
						<input name="expiresAt" type="datetime-local" class="w-full rounded border border-zinc-300 bg-white px-3 py-2 text-sm outline-none transition focus:border-zinc-500 dark:border-zinc-700 dark:bg-zinc-900" />
					</label>
					<button type="submit" class="w-full rounded border border-zinc-900 bg-zinc-900 px-4 py-2 text-sm text-white transition hover:bg-zinc-700 dark:border-zinc-100 dark:bg-zinc-100 dark:text-zinc-900 dark:hover:bg-zinc-300">
						Create token
					</button>
				</form>

				<div id="token-secret-panel" class="mt-4 hidden rounded border border-emerald-300 bg-emerald-50 p-4 dark:border-emerald-800 dark:bg-emerald-900/20">
					<div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
						<div>
							<h3 class="text-base font-semibold text-emerald-950 dark:text-emerald-100">New Token Secret</h3>
							<p class="mt-1 text-sm text-emerald-900 dark:text-emerald-200">
								Copy this now. It will not be shown again after this response.
							</p>
						</div>
					</div>
					<div id="token-secret-block" class="mt-3 overflow-hidden rounded border border-emerald-300/70 dark:border-emerald-800">
						<Code code="Token will appear here after creation or rotation." lang="plaintext" />
					</div>
				</div>

				<div class="mt-4 rounded border border-zinc-200 p-4 text-sm text-zinc-600 dark:border-zinc-800 dark:text-zinc-300">
					<div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
						<div>
							<h3 class="text-base font-semibold text-zinc-900 dark:text-zinc-100">Using bearer auth</h3>
							<p id="curl-selection-label" class="mt-1 text-xs text-zinc-500 dark:text-zinc-400">
								Create or rotate a token to fill this command.
							</p>
						</div>
					</div>
					<div id="curl-command-block" class="mt-3 overflow-hidden rounded border border-zinc-200 dark:border-zinc-800">
						<Code code={'curl -H "Authorization: Bearer <token>" "https://fdke.vin/api/ping"'} lang="bash" />
					</div>
				</div>
			</div>

			<div class="rounded border border-zinc-200 p-4 dark:border-zinc-800 md:p-5">
				<div class="flex items-start justify-between gap-4">
					<div class="space-y-1">
						<h2 class="text-lg font-semibold">Issued Tokens</h2>
						<p class="text-sm text-zinc-600 dark:text-zinc-300">
							Create, rotate, revoke, and update scopes or expiration.
						</p>
					</div>
					<button
						id="refresh-tokens"
						type="button"
						class="rounded border border-zinc-300 px-3 py-2 text-xs tracking-[0.18em] uppercase transition-colors hover:bg-zinc-50 dark:border-zinc-700 dark:hover:bg-zinc-800"
					>
						Refresh
					</button>
				</div>
				<div id="tokens-feedback" class="hidden rounded border px-3 py-2 text-sm"></div>
				<div id="tokens-empty" class="rounded border border-dashed border-zinc-200 p-5 text-sm text-zinc-600 dark:border-zinc-800 dark:text-zinc-300">
					No API tokens yet.
				</div>
				<div id="tokens-list" class="space-y-3"></div>
			</div>
		</div>
	</section>

	<script is:inline define:vars={{ scopes: API_SCOPES }}>
		const scopesList = scopes;
		const tokensList = document.getElementById("tokens-list");
		const tokensEmpty = document.getElementById("tokens-empty");
		const tokensFeedback = document.getElementById("tokens-feedback");
		const tokenSecretPanel = document.getElementById("token-secret-panel");
		const createForm = document.getElementById("create-token-form");
		const refreshButton = document.getElementById("refresh-tokens");
		const curlSelectionLabel = document.getElementById("curl-selection-label");

		let currentTokens = [];
		let revealedTokenId = null;
		let revealedTokenSecret = "";
		let selectedTokenId = null;

		function setCodeBlockValue(blockId, value) {
			const codeElement = document.querySelector(`#${blockId} code`);
			if (codeElement) {
				codeElement.textContent = value;
			}
		}

		function formatDate(value) {
			if (!value) return "Never";
			const date = new Date(value);
			return Number.isNaN(date.getTime()) ? "Invalid" : date.toLocaleString();
		}

		function showFeedback(message, tone) {
			if (!tokensFeedback) return;
			tokensFeedback.textContent = message;
			tokensFeedback.className = `rounded border px-3 py-2 text-sm ${tone === "error" ? "border-red-300 bg-red-50 text-red-800 dark:border-red-800 dark:bg-red-900/20 dark:text-red-300" : "border-emerald-300 bg-emerald-50 text-emerald-800 dark:border-emerald-800 dark:bg-emerald-900/20 dark:text-emerald-300"}`;
			tokensFeedback.classList.remove("hidden");
		}

		function clearFeedback() {
			tokensFeedback?.classList.add("hidden");
		}

		function showSecret(secret) {
			if (!tokenSecretPanel) return;
			setCodeBlockValue("token-secret-block", secret);
			tokenSecretPanel.classList.remove("hidden");
		}

		function getCurlCommand(secret) {
			const token = secret || "<token>";
			return `curl -H "Authorization: Bearer ${token}" "https://fdke.vin/api/ping"`;
		}

		function renderCurlCommand() {
			setCodeBlockValue(
				"curl-command-block",
				getCurlCommand(selectedTokenId === revealedTokenId ? revealedTokenSecret : ""),
			);

			if (!curlSelectionLabel) return;
			if (!selectedTokenId || selectedTokenId !== revealedTokenId || !revealedTokenSecret) {
				curlSelectionLabel.textContent = "Create or rotate a token to fill this command.";
				return;
			}

			const token = currentTokens.find((entry) => entry.id === selectedTokenId);
			curlSelectionLabel.textContent = token
				? `Curl command is using ${token.name} (${token.prefix}).`
				: "Curl command is using the latest revealed token.";
		}

		function getPayloadFromForm(form) {
			const data = new FormData(form);
			const expiresAt = data.get("expiresAt");
			return {
				name: String(data.get("name") || "").trim(),
				scopes: data.getAll("scopes"),
				expiresAt: expiresAt ? new Date(String(expiresAt)).toISOString() : null,
			};
		}

		function buildTokenCard(token) {
			const isSelected = token.id === selectedTokenId;
			const isRevealed = token.id === revealedTokenId && Boolean(revealedTokenSecret);
			const cardBorder = isSelected
				? "border-emerald-400 dark:border-emerald-700"
				: "border-zinc-200 dark:border-zinc-800";
			const statusBadge = token.revokedAt
				? '<span class="rounded bg-red-100 px-2 py-1 text-[11px] text-red-700 dark:bg-red-900/40 dark:text-red-300">Revoked</span>'
				: '<span class="rounded bg-emerald-100 px-2 py-1 text-[11px] text-emerald-700 dark:bg-emerald-900/40 dark:text-emerald-300">Active</span>';
			const revealBadge = isRevealed
				? '<span class="rounded bg-amber-100 px-2 py-1 text-[11px] text-amber-800 dark:bg-amber-900/40 dark:text-amber-200">Ready for curl</span>'
				: "";
			const selectedBadge = isSelected
				? '<span class="rounded bg-emerald-100 px-2 py-1 text-[11px] text-emerald-800 dark:bg-emerald-900/40 dark:text-emerald-200">Selected</span>'
				: "";
			const revealHint = isRevealed
				? '<p class="mb-4 rounded border border-emerald-300 bg-emerald-50 px-3 py-2 text-xs text-emerald-900 dark:border-emerald-800 dark:bg-emerald-900/20 dark:text-emerald-200">Click this row to use the latest revealed token in the curl command.</p>'
				: "";
			const scopeOptions = scopesList
				.map(
					(scope) => `<label class="flex items-center gap-2 text-xs"><input type="checkbox" name="scopes" value="${scope}" ${token.scopes.includes(scope) ? "checked" : ""} /> <span class="font-mono">${scope}</span></label>`,
				)
				.join("");

			return `<details class="rounded border ${cardBorder}" data-token-row="${token.id}">
				<summary class="flex cursor-pointer list-none flex-col gap-3 p-4 lg:flex-row lg:items-center lg:justify-between">
					<div class="space-y-2">
						<div class="flex flex-wrap items-center gap-2">
							<h3 class="text-base font-semibold text-zinc-900 dark:text-zinc-100">${token.name}</h3>
							<span class="rounded bg-zinc-100 px-2 py-1 text-[11px] text-zinc-700 dark:bg-zinc-900 dark:text-zinc-200">Prefix ${token.prefix}</span>
							${statusBadge}
							${revealBadge}
							${selectedBadge}
						</div>
						<div class="grid gap-1 text-xs text-zinc-600 dark:text-zinc-300 sm:grid-cols-3 sm:gap-3">
							<div>Created: ${formatDate(token.createdAt)}</div>
							<div>Last used: ${formatDate(token.lastUsedAt)}</div>
							<div>Expires: ${formatDate(token.expiresAt)}</div>
						</div>
					</div>
					<div class="shrink-0 text-xs tracking-[0.18em] text-zinc-500 uppercase dark:text-zinc-400">Edit</div>
				</summary>
				<div class="border-t border-zinc-200 p-4 dark:border-zinc-800">
					${revealHint}
					<div class="mb-4 flex flex-wrap gap-2">
						<button type="button" data-action="rotate" data-id="${token.id}" class="rounded border border-zinc-300 px-3 py-2 text-xs uppercase transition hover:bg-zinc-50 dark:border-zinc-700 dark:hover:bg-zinc-800">Rotate</button>
						<button type="button" data-action="delete" data-id="${token.id}" class="rounded border border-red-300 px-3 py-2 text-xs uppercase text-red-700 transition hover:bg-red-50 dark:border-red-800 dark:text-red-300 dark:hover:bg-red-900/20">Delete</button>
					</div>
					<form class="space-y-3" data-token-id="${token.id}">
						<label class="block space-y-2 text-sm">
							<span>Name</span>
							<input name="name" value="${escapeHtml(token.name)}" class="w-full rounded border border-zinc-300 bg-white px-3 py-2 text-sm dark:border-zinc-700 dark:bg-zinc-900" />
						</label>
						<label class="block space-y-2 text-sm">
							<span>Expire at</span>
							<input name="expiresAt" type="datetime-local" value="${toDatetimeLocal(token.expiresAt)}" class="w-full rounded border border-zinc-300 bg-white px-3 py-2 text-sm dark:border-zinc-700 dark:bg-zinc-900" />
						</label>
						<div class="grid gap-2 sm:grid-cols-2">${scopeOptions}</div>
						<button type="submit" class="rounded border border-zinc-900 bg-zinc-900 px-4 py-2 text-xs uppercase text-white transition hover:bg-zinc-700 dark:border-zinc-100 dark:bg-zinc-100 dark:text-zinc-900 dark:hover:bg-zinc-300">Save changes</button>
					</form>
				</div>
			</details>`;
		}

		function toDatetimeLocal(value) {
			if (!value) return "";
			const date = new Date(value);
			if (Number.isNaN(date.getTime())) return "";
			const offset = date.getTimezoneOffset();
			const local = new Date(date.getTime() - offset * 60 * 1000);
			return local.toISOString().slice(0, 16);
		}

		function escapeHtml(value) {
			return value.replaceAll("&", "&amp;").replaceAll("<", "&lt;").replaceAll(">", "&gt;").replaceAll('"', "&quot;");
		}

		function renderTokens(tokens) {
			currentTokens = tokens;
			if (!tokensList || !tokensEmpty) return;
			tokensList.innerHTML = tokens.map(buildTokenCard).join("");
			tokensEmpty.style.display = tokens.length === 0 ? "block" : "none";
		}

		function rememberRevealedToken(token, secret) {
			revealedTokenId = token?.id ?? null;
			revealedTokenSecret = secret;
			selectedTokenId = token?.id ?? null;
			showSecret(secret);
			renderCurlCommand();
		}

		async function loadTokens() {
			clearFeedback();
			const response = await fetch("/api/tokens", { headers: { Accept: "application/json" } });
			const data = await response.json();
			if (!response.ok) {
				throw new Error(data.error || "Failed to load tokens");
			}

			const tokens = data.tokens || [];
			renderTokens(tokens);
			renderCurlCommand();
		}

		createForm?.addEventListener("submit", async (event) => {
			event.preventDefault();
			clearFeedback();
			const form = event.currentTarget;
			if (!(form instanceof HTMLFormElement)) return;

			const response = await fetch("/api/tokens", {
				method: "POST",
				headers: { "Content-Type": "application/json" },
				body: JSON.stringify(getPayloadFromForm(form)),
			});
			const data = await response.json();
			if (!response.ok) {
				showFeedback(data.error || "Failed to create token", "error");
				return;
			}

			form.reset();
			for (const input of form.querySelectorAll('input[name="scopes"]')) {
				if (input instanceof HTMLInputElement) {
					input.checked = input.value === "api.ping";
				}
			}
			rememberRevealedToken(data.token, data.secret);
			showFeedback("Token created.", "success");
			await loadTokens();
		});

		refreshButton?.addEventListener("click", async () => {
			try {
				await loadTokens();
				showFeedback("Token list refreshed.", "success");
			} catch (error) {
				showFeedback(error instanceof Error ? error.message : "Failed to refresh tokens", "error");
			}
		});

		tokensList?.addEventListener("submit", async (event) => {
			event.preventDefault();
			const form = event.target;
			if (!(form instanceof HTMLFormElement)) return;

			const tokenId = form.dataset.tokenId;
			if (!tokenId) return;

			const response = await fetch(`/api/tokens/${tokenId}`, {
				method: "PATCH",
				headers: { "Content-Type": "application/json" },
				body: JSON.stringify(getPayloadFromForm(form)),
			});
			const data = await response.json();
			if (!response.ok) {
				showFeedback(data.error || "Failed to update token", "error");
				return;
			}

			showFeedback("Token updated.", "success");
			await loadTokens();
		});

		tokensList?.addEventListener("click", async (event) => {
			const target = event.target;
			if (!(target instanceof Element)) return;

			const summary = target.closest("summary");
			if (summary instanceof HTMLElement && tokensList.contains(summary)) {
				const details = summary.closest("details[data-token-row]");
				const tokenId = details?.getAttribute("data-token-row");
				if (tokenId && tokenId === revealedTokenId && revealedTokenSecret) {
					selectedTokenId = tokenId;
					renderCurlCommand();
				}
				return;
			}

			if (!(target instanceof HTMLButtonElement)) return;
			const tokenId = target.dataset.id;
			const action = target.dataset.action;
			if (!tokenId || !action) return;

			if (action === "delete") {
				const response = await fetch(`/api/tokens/${tokenId}`, { method: "DELETE" });
				const data = await response.json();
				if (!response.ok) {
					showFeedback(data.error || "Failed to delete token", "error");
					return;
				}

				if (selectedTokenId === tokenId) {
					selectedTokenId = null;
				}
				if (revealedTokenId === tokenId) {
					revealedTokenId = null;
					revealedTokenSecret = "";
					if (tokenSecretPanel) {
						tokenSecretPanel.classList.add("hidden");
					}
				}
				renderCurlCommand();
				showFeedback("Token deleted.", "success");
				await loadTokens();
				return;
			}

			if (action === "rotate") {
				const response = await fetch(`/api/tokens/${tokenId}/rotate`, { method: "POST" });
				const data = await response.json();
				if (!response.ok) {
					showFeedback(data.error || "Failed to rotate token", "error");
					return;
				}

				rememberRevealedToken(data.token, data.secret);
				showFeedback("Token rotated. Old token is revoked.", "success");
				await loadTokens();
			}
		});

		renderCurlCommand();
		loadTokens().catch((error) => {
			showFeedback(error instanceof Error ? error.message : "Failed to load tokens", "error");
		});
	</script>
</Layout>
