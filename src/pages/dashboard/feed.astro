---
import Layout from "@/layouts/Base.astro";

export const prerender = false;

const user = Astro.locals.user;
---

<Layout
	meta={{
		title: "Dashboard Feed",
		description: "Manage the shared RSS feed pool and monitor ingestion.",
	}}
>
	<section class="space-y-6">
		<div class="space-y-3">
			<p class="text-[11px] tracking-[0.42em] text-zinc-500 uppercase dark:text-zinc-400">
				<a href="/dashboard" class="hover:underline">Dashboard</a> / Feed
			</p>
			<div class="flex flex-col gap-3 md:flex-row md:items-start md:justify-between">
				<div class="space-y-2">
					<h1 class="title text-2xl">Dashboard Feed</h1>
				</div>
				{
					user && (
						<div class="rounded border border-zinc-200 px-3 py-2 text-sm text-zinc-600 dark:border-zinc-800 dark:text-zinc-300">
							Signed in as{" "}
							<span class="font-medium text-zinc-900 dark:text-zinc-100">{user.email}</span>
						</div>
					)
				}
			</div>
		</div>

		<div class="space-y-6">
			<section class="rounded border border-zinc-200 p-4 md:p-5 dark:border-zinc-800">
				<div class="flex flex-col gap-3 lg:flex-row lg:items-start lg:justify-between">
					<div class="space-y-1">
						<h2 class="text-lg font-semibold">Feed Sources</h2>
					</div>
					<div class="flex flex-wrap gap-2">
						<button
							id="open-create-feed"
							type="button"
							class="rounded border border-zinc-300 px-3 py-2 text-xs tracking-[0.18em] uppercase transition hover:bg-zinc-50 dark:border-zinc-700 dark:hover:bg-zinc-800"
						>
							Add
						</button>
						<button
							id="sync-feed-run"
							type="button"
							class="rounded border border-zinc-900 bg-zinc-900 px-3 py-2 text-xs tracking-[0.18em] text-white uppercase transition hover:bg-zinc-700 dark:border-zinc-100 dark:bg-zinc-100 dark:text-zinc-900 dark:hover:bg-zinc-300"
						>
							Run
						</button>
						<button
							id="refresh-feed-data"
							type="button"
							class="rounded border border-zinc-300 px-3 py-2 text-xs tracking-[0.18em] uppercase transition hover:bg-zinc-50 dark:border-zinc-700 dark:hover:bg-zinc-800"
						>
							Refresh
						</button>
					</div>
				</div>

				<div id="feed-feedback" class="mt-4 hidden rounded border px-3 py-2 text-sm"></div>

				<div
					id="feeds-empty"
					class="mt-4 rounded border border-dashed border-zinc-200 p-5 text-sm text-zinc-600 dark:border-zinc-800 dark:text-zinc-300"
				>
					No shared feeds yet.
				</div>
				<div id="feeds-list" class="mt-4 space-y-3"></div>
			</section>

			<section class="rounded border border-zinc-200 p-4 md:p-5 dark:border-zinc-800">
				<div class="space-y-1">
					<h2 class="text-lg font-semibold">Recent Ingested Items</h2>
				</div>
				<div
					id="feed-items-empty"
					class="mt-4 rounded border border-dashed border-zinc-200 p-5 text-sm text-zinc-600 dark:border-zinc-800 dark:text-zinc-300"
				>
					No items ingested yet.
				</div>
				<div id="feed-items-list" class="mt-4 space-y-3"></div>
			</section>
		</div>

		<dialog
			id="create-feed-dialog"
			aria-label="Add Feed Source"
			class="bg-global-bg h-full max-h-full w-full max-w-full border border-zinc-300 shadow-sm backdrop:backdrop-blur-sm open:flex sm:mx-auto sm:mt-16 sm:mb-auto sm:h-max sm:max-h-[calc(100%-8rem)] sm:min-h-[18rem] sm:w-full sm:max-w-xl sm:rounded-md dark:border-zinc-700"
		>
			<div class="dialog-frame flex grow flex-col gap-5 p-6 pt-12 sm:pt-6">
				<div class="flex items-start justify-between gap-4">
					<div class="space-y-2">
						<p class="text-[11px] tracking-[0.24em] text-zinc-500 uppercase dark:text-zinc-400">
							Add Feed Source
						</p>
						<div class="space-y-1">
							<h2 class="text-lg font-semibold text-zinc-900 dark:text-zinc-100">Add feed</h2>
						</div>
					</div>
					<button
						data-close-create-feed
						type="button"
						class="cursor-pointer rounded border border-zinc-300 px-3 py-2 text-xs tracking-[0.18em] uppercase transition hover:bg-zinc-50 dark:border-zinc-700 dark:hover:bg-zinc-800"
					>
						Close
					</button>
				</div>

				<form id="create-feed-form" class="space-y-4">
					<label class="block space-y-2 text-sm">
						<span class="text-zinc-700 dark:text-zinc-200">Feed URL</span>
						<input
							id="create-feed-url"
							name="feedUrl"
							required
							type="url"
							placeholder="https://example.com/feed.xml"
							class="w-full rounded border border-zinc-300 bg-white px-3 py-2 text-sm transition outline-none focus:border-zinc-500 dark:border-zinc-700 dark:bg-zinc-900"
						/>
					</label>
					<div class="grid gap-3 sm:grid-cols-2">
						<label
							class="flex items-center gap-3 rounded border border-zinc-200 px-3 py-2 text-sm dark:border-zinc-800"
						>
							<input name="isActive" type="checkbox" checked />
							<span>Active</span>
						</label>
						<label
							class="flex items-center gap-3 rounded border border-zinc-200 px-3 py-2 text-sm dark:border-zinc-800"
						>
							<input name="fetchMarkdown" type="checkbox" checked />
							<span>Fetch article markdown/text</span>
						</label>
					</div>
					<button
						type="submit"
						class="w-full rounded border border-zinc-900 bg-zinc-900 px-4 py-2 text-sm text-white transition hover:bg-zinc-700 dark:border-zinc-100 dark:bg-zinc-100 dark:text-zinc-900 dark:hover:bg-zinc-300"
					>
						Add feed source
					</button>
				</form>
			</div>
		</dialog>
	</section>

	<script is:inline>
		const feedback = document.getElementById("feed-feedback");
		const feedsList = document.getElementById("feeds-list");
		const feedsEmpty = document.getElementById("feeds-empty");
		const createDialog = document.getElementById("create-feed-dialog");
		const createForm = document.getElementById("create-feed-form");
		const openCreateButton = document.getElementById("open-create-feed");
		const createFeedUrlInput = document.getElementById("create-feed-url");
		const refreshButton = document.getElementById("refresh-feed-data");
		const syncButton = document.getElementById("sync-feed-run");
		const itemsList = document.getElementById("feed-items-list");
		const itemsEmpty = document.getElementById("feed-items-empty");

		function setFeedback(message, tone = "success") {
			if (!feedback) return;
			feedback.textContent = message;
			feedback.className = `mt-4 rounded border px-3 py-2 text-sm ${
				tone === "error"
					? "border-red-300 bg-red-50 text-red-800 dark:border-red-800 dark:bg-red-900/20 dark:text-red-300"
					: "border-emerald-300 bg-emerald-50 text-emerald-800 dark:border-emerald-800 dark:bg-emerald-900/20 dark:text-emerald-300"
			}`;
			feedback.classList.remove("hidden");
		}

		function clearFeedback() {
			feedback?.classList.add("hidden");
		}

		function getFeedPayload(form) {
			const data = new FormData(form);
			return {
				feedUrl: String(data.get("feedUrl") || "").trim(),
				isActive: data.get("isActive") === "on",
				fetchMarkdown: data.get("fetchMarkdown") === "on",
			};
		}

		function getEditableFeedPayload(form) {
			const data = new FormData(form);
			return {
				title: String(data.get("title") || "").trim(),
				feedUrl: String(data.get("feedUrl") || "").trim(),
				siteUrl: String(data.get("siteUrl") || "").trim() || null,
				isActive: data.get("isActive") === "on",
				fetchMarkdown: data.get("fetchMarkdown") === "on",
			};
		}

		function openCreateDialog() {
			if (!(createDialog instanceof HTMLDialogElement)) return;
			createDialog.showModal();
			window.setTimeout(() => {
				if (createFeedUrlInput instanceof HTMLInputElement) {
					createFeedUrlInput.focus();
				}
			}, 0);
		}

		function closeCreateDialog() {
			if (createDialog instanceof HTMLDialogElement) {
				createDialog.close();
			}
		}

		function formatDate(value) {
			if (!value) return "-";
			const date = new Date(value);
			return Number.isNaN(date.getTime()) ? value : date.toLocaleString();
		}

		function escapeHtml(value) {
			return String(value)
				.replaceAll("&", "&amp;")
				.replaceAll("<", "&lt;")
				.replaceAll(">", "&gt;")
				.replaceAll('"', "&quot;");
		}

		function renderFeeds(feeds) {
			if (!feedsList || !feedsEmpty) return;
			feedsEmpty.style.display = feeds.length ? "none" : "block";
			feedsList.innerHTML = feeds
				.map(
					(feed) => `<details class="rounded border border-zinc-200 dark:border-zinc-800">
						<summary class="flex cursor-pointer list-none flex-col gap-3 p-4 lg:flex-row lg:items-start lg:justify-between">
							<div class="space-y-2">
								<div class="flex flex-wrap items-center gap-2">
									<h3 class="text-base font-semibold text-zinc-900 dark:text-zinc-100">${escapeHtml(feed.title)}</h3>
									<span class="rounded px-2 py-1 text-[11px] ${feed.isActive ? "bg-emerald-100 text-emerald-700 dark:bg-emerald-900/40 dark:text-emerald-300" : "bg-zinc-100 text-zinc-700 dark:bg-zinc-900 dark:text-zinc-300"}">${feed.isActive ? "Active" : "Paused"}</span>
									<span class="rounded px-2 py-1 text-[11px] ${feed.fetchMarkdown ? "bg-sky-100 text-sky-700 dark:bg-sky-900/40 dark:text-sky-300" : "bg-zinc-100 text-zinc-700 dark:bg-zinc-900 dark:text-zinc-300"}">${feed.fetchMarkdown ? "Fetch article text" : "Feed-only"}</span>
								</div>
								<div class="space-y-1 text-xs text-zinc-600 dark:text-zinc-300">
									<div><span class="font-medium">Feed:</span> <a href="${escapeHtml(feed.feedUrl)}" target="_blank" rel="noopener noreferrer" class="underline decoration-zinc-300 underline-offset-4">${escapeHtml(feed.feedUrl)}</a></div>
									${feed.siteUrl ? `<div><span class="font-medium">Site:</span> <a href="${escapeHtml(feed.siteUrl)}" target="_blank" rel="noopener noreferrer" class="underline decoration-zinc-300 underline-offset-4">${escapeHtml(feed.siteUrl)}</a></div>` : ""}
									<div><span class="font-medium">Last fetched:</span> ${escapeHtml(formatDate(feed.lastFetchedAt))}</div>
									<div><span class="font-medium">Last error:</span> ${escapeHtml(feed.lastError || "None")}</div>
								</div>
							</div>
							<div class="shrink-0 text-xs tracking-[0.18em] text-zinc-500 uppercase dark:text-zinc-400">Edit</div>
						</summary>
						<div class="border-t border-zinc-200 p-4 dark:border-zinc-800">
							<form class="space-y-3" data-feed-id="${escapeHtml(feed.id)}">
								<label class="block space-y-2 text-sm">
									<span>Feed title</span>
									<input name="title" value="${escapeHtml(feed.title)}" class="w-full rounded border border-zinc-300 bg-white px-3 py-2 text-sm dark:border-zinc-700 dark:bg-zinc-900" />
								</label>
								<label class="block space-y-2 text-sm">
									<span>Feed URL</span>
									<input name="feedUrl" value="${escapeHtml(feed.feedUrl)}" class="w-full rounded border border-zinc-300 bg-white px-3 py-2 text-sm dark:border-zinc-700 dark:bg-zinc-900" />
								</label>
								<label class="block space-y-2 text-sm">
									<span>Site URL</span>
									<input name="siteUrl" value="${escapeHtml(feed.siteUrl || "")}" class="w-full rounded border border-zinc-300 bg-white px-3 py-2 text-sm dark:border-zinc-700 dark:bg-zinc-900" />
								</label>
								<div class="grid gap-3 sm:grid-cols-2">
									<label class="flex items-center gap-3 rounded border border-zinc-200 px-3 py-2 text-sm dark:border-zinc-800">
										<input name="isActive" type="checkbox" ${feed.isActive ? "checked" : ""} />
										<span>Active</span>
									</label>
									<label class="flex items-center gap-3 rounded border border-zinc-200 px-3 py-2 text-sm dark:border-zinc-800">
										<input name="fetchMarkdown" type="checkbox" ${feed.fetchMarkdown ? "checked" : ""} />
										<span>Fetch article text</span>
									</label>
								</div>
								<div class="flex flex-wrap gap-2">
									<button type="submit" class="rounded border border-zinc-900 bg-zinc-900 px-4 py-2 text-xs uppercase text-white transition hover:bg-zinc-700 dark:border-zinc-100 dark:bg-zinc-100 dark:text-zinc-900 dark:hover:bg-zinc-300">Save</button>
									<button type="button" data-action="delete" data-id="${escapeHtml(feed.id)}" class="rounded border border-red-300 px-4 py-2 text-xs uppercase text-red-700 transition hover:bg-red-50 dark:border-red-800 dark:text-red-300 dark:hover:bg-red-900/20">Delete</button>
								</div>
							</form>
						</div>
					</details>`,
				)
				.join("");
		}

		function renderItems(items) {
			if (!itemsList || !itemsEmpty) return;
			itemsEmpty.style.display = items.length ? "none" : "block";
			itemsList.innerHTML = items
				.map(
					(item) => {
						const hasOriginalLanguage = item.sourceLanguage && item.sourceLanguage.toLowerCase() !== "en";
						const defaultTitle = item.titleEn || item.title;
						const defaultDescription = item.descriptionEn || item.description || "";
						const originalTitle = hasOriginalLanguage ? item.title : defaultTitle;
						const originalDescription = hasOriginalLanguage ? item.description : defaultDescription;
						const pubDate = item.publishedAt
							? new Date(item.publishedAt).toLocaleDateString(undefined, {
									day: "numeric",
									month: "short",
									year: "numeric",
								})
							: "Date unavailable";

						return `<feed-item-card class="block">
							<article class="rounded border border-zinc-200 bg-white p-5 transition-colors hover:border-zinc-400 dark:border-zinc-800 dark:bg-zinc-950 dark:hover:border-zinc-600">
								<div class="flex flex-col gap-3">
									<div class="flex items-start justify-between gap-3">
										<div class="min-w-0 flex-1 space-y-1">
											<p class="text-[11px] tracking-[0.22em] text-zinc-500 uppercase dark:text-zinc-400">${escapeHtml(item.feedTitle)}</p>
											<h2 class="text-lg font-semibold text-zinc-900 dark:text-zinc-100">
												<a href="${escapeHtml(item.url)}" target="_blank" rel="noopener noreferrer" class="hover:underline line-clamp-2">
													<span data-title-en>${escapeHtml(defaultTitle)}</span>
													<span data-title-original class="hidden">${escapeHtml(originalTitle)}</span>
												</a>
											</h2>
										</div>
										${hasOriginalLanguage ? `<button type="button" data-lang-toggle class="shrink-0 rounded border border-zinc-300 px-2.5 py-1.5 text-xs tracking-[0.18em] uppercase transition hover:bg-zinc-50 dark:border-zinc-700 dark:hover:bg-zinc-800" title="Toggle language">
											<span data-lang-label>${escapeHtml(item.sourceLanguage.toUpperCase())}</span>
										</button>` : ""}
									</div>
									<div class="space-y-2">
										<p class="text-sm leading-relaxed text-zinc-600 dark:text-zinc-300 line-clamp-3">
											<span data-desc-en>${escapeHtml(defaultDescription)}</span>
											<span data-desc-original class="hidden">${escapeHtml(originalDescription)}</span>
										</p>
									</div>
									<div class="flex items-center gap-3 text-xs text-zinc-500 dark:text-zinc-400">
										<time>${pubDate}</time>
										${hasOriginalLanguage ? "<span>•</span>" : ""}
										${hasOriginalLanguage ? `<span class="text-[11px] tracking-[0.18em] uppercase">${escapeHtml(item.sourceLanguage)}</span>` : ""}
									</div>
									<div class="pt-2">
										<a href="${escapeHtml(item.url)}" target="_blank" rel="noopener noreferrer" class="inline-flex items-center rounded border border-zinc-300 px-3 py-1.5 text-xs tracking-[0.18em] uppercase transition hover:bg-zinc-50 dark:border-zinc-700 dark:hover:bg-zinc-800">
											Read
										</a>
									</div>
								</div>
							</article>
						</feed-item-card>`;
					},
				)
				.join("");
		}

		async function loadAll() {
			clearFeedback();
			const [feedsResponse, itemsResponse] = await Promise.all([
				fetch("/api/feed/sources", { headers: { Accept: "application/json" } }),
				fetch("/api/feed/items?limit=30", { headers: { Accept: "application/json" } }),
			]);

			const [feedsData, itemsData] = await Promise.all([
				feedsResponse.json(),
				itemsResponse.json(),
			]);

			if (!feedsResponse.ok) throw new Error(feedsData.error || "Failed to load feeds");
			if (!itemsResponse.ok) throw new Error(itemsData.error || "Failed to load feed items");

			renderFeeds(feedsData.feeds || []);
			renderItems(itemsData.items || []);
		}

		createForm?.addEventListener("submit", async (event) => {
			event.preventDefault();
			const form = event.currentTarget;
			if (!(form instanceof HTMLFormElement)) return;
			const submitButton = form.querySelector('button[type="submit"]');
			if (submitButton instanceof HTMLButtonElement) {
				submitButton.disabled = true;
				submitButton.textContent = "Adding...";
			}
			const response = await fetch("/api/feed/sources", {
				method: "POST",
				headers: { "Content-Type": "application/json" },
				body: JSON.stringify(getFeedPayload(form)),
			});
			const data = await response.json();
			if (submitButton instanceof HTMLButtonElement) {
				submitButton.disabled = false;
				submitButton.textContent = "Add feed source";
			}
			if (!response.ok) {
				setFeedback(data.error || "Failed to create feed source", "error");
				return;
			}
			form.reset();
			for (const checkbox of form.querySelectorAll('input[type="checkbox"]')) {
				if (checkbox instanceof HTMLInputElement) checkbox.checked = true;
			}
			closeCreateDialog();
			setFeedback(
				`Feed source added${data.feed?.title ? `: ${data.feed.title}` : ""}. Metadata fetched from the feed URL.`,
			);
			await loadAll();
		});

		openCreateButton?.addEventListener("click", openCreateDialog);

		createDialog?.addEventListener("click", (event) => {
			if (!(createDialog instanceof HTMLDialogElement)) return;
			if (event.target === createDialog) {
				closeCreateDialog();
			}
		});

		document
			.querySelector("[data-close-create-feed]")
			?.addEventListener("click", closeCreateDialog);

		refreshButton?.addEventListener("click", async () => {
			try {
				await loadAll();
				setFeedback("Feed data refreshed.");
			} catch (error) {
				setFeedback(
					error instanceof Error ? error.message : "Failed to refresh feed data",
					"error",
				);
			}
		});

		syncButton?.addEventListener("click", async () => {
			const response = await fetch("/api/feed/sync", { method: "POST" });
			const data = await response.json();
			if (!response.ok) {
				setFeedback(data.error || "Failed to start feed sync", "error");
				return;
			}
			setFeedback(
				`Feed sync queued${data.run?.pending ? ` for ${data.run.pending} active feeds` : ""}.`,
			);
		});

		feedsList?.addEventListener("submit", async (event) => {
			event.preventDefault();
			const form = event.target;
			if (!(form instanceof HTMLFormElement)) return;
			const feedId = form.dataset.feedId;
			if (!feedId) return;

			const response = await fetch(`/api/feed/sources/${feedId}`, {
				method: "PATCH",
				headers: { "Content-Type": "application/json" },
				body: JSON.stringify(getEditableFeedPayload(form)),
			});
			const data = await response.json();
			if (!response.ok) {
				setFeedback(data.error || "Failed to update feed source", "error");
				return;
			}

			setFeedback("Feed source updated.");
			await loadAll();
		});

		feedsList?.addEventListener("click", async (event) => {
			const target = event.target;
			if (!(target instanceof HTMLButtonElement)) return;
			if (target.dataset.action !== "delete" || !target.dataset.id) return;

			const response = await fetch(`/api/feed/sources/${target.dataset.id}`, { method: "DELETE" });
			const data = await response.json();
			if (!response.ok) {
				setFeedback(data.error || "Failed to delete feed source", "error");
				return;
			}

			setFeedback("Feed source deleted.");
			await loadAll();
		});

		loadAll().catch((error) => {
			setFeedback(
				error instanceof Error ? error.message : "Failed to load Dashboard Feed",
				"error",
			);
		});

		class FeedItemCardElement extends HTMLElement {
			#isEnglish = true;

			connectedCallback() {
				const toggleButton = this.querySelector("[data-lang-toggle]");
				if (!toggleButton) return;

				const titleEn = this.querySelector("[data-title-en]");
				const titleOriginal = this.querySelector("[data-title-original]");
				const descEn = this.querySelector("[data-desc-en]");
				const descOriginal = this.querySelector("[data-desc-original]");
				const langLabel = this.querySelector("[data-lang-label]");

				if (!titleEn || !titleOriginal || !descEn || !descOriginal || !langLabel) return;

				toggleButton.addEventListener("click", () => {
					this.#isEnglish = !this.#isEnglish;

					if (this.#isEnglish) {
						titleEn.classList.remove("hidden");
						titleOriginal.classList.add("hidden");
						descEn.classList.remove("hidden");
						descOriginal.classList.add("hidden");
					} else {
						titleEn.classList.add("hidden");
						titleOriginal.classList.remove("hidden");
						descEn.classList.add("hidden");
						descOriginal.classList.remove("hidden");
					}
				});
			}
		}

		if (!customElements.get("feed-item-card")) {
			customElements.define("feed-item-card", FeedItemCardElement);
		}
	</script>
</Layout>
