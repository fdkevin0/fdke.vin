---
import PageLayout from "@/layouts/Base.astro";

// Server-rendered so SSR routes can `Astro.rewrite("/404")` to it — rewriting
// to a prerendered route is a runtime error. Astro's renderPage forces the
// response status to 404 for the `/404` route, so no explicit status is needed.
export const prerender = false;

const meta = {
	description: "This page does not exist on fdke.vin.",
	title: "Page Not Found",
};
---

<PageLayout meta={meta}>
	<h1 class="title mb-12">404 | Page not found</h1>
	<p class="mb-8">Use the navigation to get back to an existing page.</p>
</PageLayout>
